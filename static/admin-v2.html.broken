<div class="stat-card"><div class="label">今日收入</div><div class="value">¥{{$parent.stats.todayAmount||\'0.00\'}}</div><div class="icon">💰</div></div>\
<div class="stat-card"><div class="label">总订单数</div><div class="value">{{$parent.stats.orderCount||0}}</div><div class="icon">📊</div></div>\
<div class="stat-card"><div class="label">在线设备</div><div class="value">{{$parent.stats.onlineCount||0}} / {{$parent.stats.deviceCount||0}}</div><div class="icon">🖥</div></div>\
<div class="stat-card"><div class="label">会员数</div><div class="value">{{$parent.stats.userCount||0}}</div><div class="icon">👤</div></div>\
<div class="stat-card"><div class="label">网点数</div><div class="value">{{$parent.stats.locationCount||0}}</div><div class="icon">📍</div></div>\
</div>\
<div class="chart-box"><h3>近7日订单趋势</h3><div id="dailyChart" style="height:300px"></div></div>\
