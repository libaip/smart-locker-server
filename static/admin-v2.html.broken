// After-sales
Vue.component('page-store-record',{template:'\
<div>\
<div class="page-box">\
<div class="box-header"><h3>售后工单</h3><div><select v-model="$parent.afterSalesStatusFilter" @change="$parent.loadAfterSales(1)" style="padding:6px;border:1px solid #d9d9d9;border-radius:4px"><option value="">全部</option><option value="pending">待处理</option><option value="processing">处理中</option><option value="resolved">已解决</option></select> <button class="btn btn-sm btn-blue" @click="$parent.showAfterSalesModal()">+ 新建工单</button></div></div>\
<table><tr><th>工单号</th><th>类型</th><th>设备</th><th>网点</th><th>描述</th><th>状态</th><th>处理人</th><th>创建时间</th><th>操作</th></tr>\
<tr v-for="a in $parent.afterSales"><td>{{a.ticket_no}}</td><td>{{a.fault_type}}</td><td>{{a.cabinet_code||\'-\'}}</td><td>{{a.location_name||\'-\'}}</td><td>{{a.description}}</td><td><span v-if="a.status===\'pending\'" class="status-tag orange">待处理</span><span v-else-if="a.status===\'processing\'" class="status-tag blue">处理中</span><span v-else class="status-tag green">已解决</span></td><td>{{a.handler||\'-\'}}</td><td>{{a.created_at}}</td><td><button class="btn-text" @click="$parent.handleAfterSales(a)">处理</button></td></tr>\
<tr v-if="!$parent.afterSales.length"><td colspan="9" class="empty-row">暂无数据</td></tr>\
</table>\
<div class="pagination"><span>共 {{$parent.afterSalesTotal}} 条</span><div><button :disabled="$parent.afterSalesPage<=1" @click="$parent.loadAfterSales($parent.afterSalesPage-1)">上一页</button><span style="margin:0 8px">{{$parent.afterSalesPage}} / {{$parent.pageCount($parent.afterSalesTotal,10)||1}}</span><button :disabled="$parent.afterSalesPage>=$parent.pageCount($parent.afterSalesTotal,10)" @click="$parent.loadAfterSales($parent.afterSalesPage+1)">下一页</button></div></div>\
</div>\
</div>'});

Vue.component('page-blacklist',{template:`
<div class="page-box">
<div class="box-header"><h3>黑名单</h3><button class="btn btn-sm btn-blue" style="float:right" @click="$parent.blackModal=true;$parent.blackForm={}">+ 新增</button></div>
