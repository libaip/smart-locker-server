<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>智能寄存柜 - 管理后台</title>
<script src="/static/js/vue.min.js"></script>
<script src="/static/libs/echarts.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','PingFang SC','Hiragino Sans GB','Microsoft YaHei',sans-serif;background:#f0f2f5;color:#333;font-size:14px}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-thumb{background:#c1c1c1;border-radius:3px}
/* Login */
.login-bg{display:flex;align-items:center;justify-content:center;min-height:100vh;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%)}
.login-card{background:#fff;border-radius:12px;padding:40px;width:380px;box-shadow:0 20px 60px rgba(0,0,0,0.3)}
.login-card h2{text-align:center;margin-bottom:30px;font-size:24px;color:#333}
.login-card .form-group{margin-bottom:20px}
.login-card label{display:block;margin-bottom:6px;font-size:13px;color:#666}
.login-card input{width:100%;padding:10px 12px;border:1px solid #d9d9d9;border-radius:6px;font-size:14px;outline:none;transition:border .3s}
.login-card input:focus{border-color:#667eea}
.captcha-row{display:flex;gap:10px;align-items:center}
.captcha-row input{flex:1}
.captcha-row canvas{cursor:pointer;border-radius:4px;border:1px solid #d9d9d9}
.btn{padding:10px 20px;border:none;border-radius:6px;cursor:pointer;font-size:14px;transition:all .3s;display:inline-flex;align-items:center;gap:6px}
.btn-primary{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;width:100%;justify-content:center;padding:12px}
.btn-primary:hover{opacity:.9}
.btn-sm{padding:6px 14px;font-size:12px;border-radius:4px}
.btn-blue{background:#409eff;color:#fff}.btn-blue:hover{background:#3a8ee6}
.btn-green{background:#67c23a;color:#fff}.btn-green:hover{background:#5daf34}
.btn-orange{background:#e6a23c;color:#fff}.btn-orange:hover{background:#cf9236}
.btn-red{background:#f56c6c;color:#fff}.btn-red:hover{background:#dd5a5a}
.btn-text{background:#E3F2FD;color:#000;padding:4px 10px;font-size:12px;border:none;border-radius:4px;cursor:pointer;margin:0 2px}
.btn-text:hover{opacity:0.85}
.btn-text.red{background:#E57373;color:#000}
.btn-text.orange{background:#FFB74D;color:#000}
.btn-text.green{background:#81C784;color:#000}
.btn-text.blue{background:#4FC3F7;color:#000}
.btn-text.purple{background:#9575CD;color:#000}
.btn-text.gray{background:#B0BEC5;color:#000}
.btn-text.teal{background:#4DB6AC;color:#000}
.btn-text.pink{background:#F06292;color:#000}
.btn-text.dark-orange{background:#FF8A65;color:#000}
.btn-text:disabled{opacity:0.5;cursor:default}
/* Layout */
.layout{display:flex;height:100vh;overflow:hidden}
.sidebar{width:220px;background:#001529;color:#fff;transition:width .3s;overflow:hidden;flex-shrink:0;display:flex;flex-direction:column}
.sidebar.shrink{width:64px}
.sidebar-header{padding:16px;text-align:center;border-bottom:1px solid rgba(255,255,255,.1);white-space:nowrap;overflow:hidden}
.sidebar-header h3{font-size:16px;color:#fff}
.sidebar-body{flex:1;overflow-y:auto;padding:8px 0}
.sidebar-footer{padding:8px 12px;border-top:1px solid rgba(255,255,255,.1);white-space:nowrap;overflow:hidden}
.sidebar-footer .user-info{color:rgba(255,255,255,.65);font-size:12px;cursor:pointer;display:flex;align-items:center;gap:6px}
.sidebar-footer .user-info:hover{color:#fff}
.menu-group{margin-bottom:2px}
.menu-group-title{padding:10px 20px;color:rgba(255,255,255,.45);font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;user-select:none}
.menu-group-title:hover{color:rgba(255,255,255,.85)}
.menu-group-title .arrow{font-size:10px;transition:transform .3s}
.menu-group-title .arrow.open{transform:rotate(90deg)}
.menu-item{padding:10px 20px 10px 36px;color:rgba(255,255,255,.65);cursor:pointer;font-size:13px;transition:all .2s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.menu-item:hover{color:#fff;background:rgba(255,255,255,.08)}
.menu-item.active{color:#fff;background:#667eea}
.shrink .menu-group-title{padding:10px 0;text-align:center;justify-content:center}
.shrink .menu-group-title span,.shrink .menu-group-title .arrow,.shrink .menu-item-text{display:none}
.shrink .menu-item{padding:10px 0;text-align:center;font-size:18px}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.topbar{height:50px;background:#fff;display:flex;align-items:center;padding:0 20px;box-shadow:0 1px 4px rgba(0,0,0,.08);gap:12px;flex-shrink:0;position:relative;z-index:101}
.topbar .toggle{cursor:pointer;font-size:20px;color:#666;padding:10px;margin:-10px 0 -10px -4px}
.topbar h1{font-size:16px;font-weight:500}
.topbar .spacer{flex:1}
.topbar .user-menu{color:#666;cursor:pointer;font-size:13px}
.content{flex:1;overflow-y:auto;padding:20px}
/* Stats */
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:20px}
.stat-card{background:#fff;border-radius:8px;padding:20px;position:relative;overflow:hidden}
.stat-card .label{font-size:13px;color:#909399;margin-bottom:8px}
.stat-card .value{font-size:28px;font-weight:600;color:#303133}
.stat-card .icon{position:absolute;right:16px;top:16px;font-size:36px;color:rgba(102,126,234,.15)}
/* Page Box */
.page-box{background:#fff;border-radius:8px;padding:20px;margin-bottom:16px}
.page-box .box-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px}
.page-box .box-header h3{font-size:16px;font-weight:500}
/* Table */
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#fafafa;padding:10px 8px;text-align:left;font-weight:500;color:#606266;border-bottom:1px solid #ebeef5;white-space:nowrap}
td{padding:10px 8px;border-bottom:1px solid #ebeef5;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
tr:hover td{background:#f5f7fa}
.empty-row td{text-align:center;color:#909399;padding:30px}
/* Sticky Action Column */
.table-scroll{overflow-x:auto;overflow-y:visible}
th.action-col{position:sticky;right:0;background:#fafafa;z-index:2;min-width:300px;max-width:350px;box-shadow:-2px 0 4px rgba(0,0,0,.06);overflow:visible}
td.action-col{position:sticky;right:0;background:#fff;z-index:1;min-width:300px;max-width:350px;box-shadow:-2px 0 4px rgba(0,0,0,.06);overflow:visible}
tr:hover td.action-col{background:#f5f7fa}
/* Pagination */
.pagination{display:flex;align-items:center;justify-content:space-between;padding:12px 0;font-size:13px;color:#606266;flex-wrap:wrap;gap:8px}
.pagination button{padding:4px 12px;border:1px solid #d9d9d9;background:#fff;border-radius:4px;cursor:pointer;font-size:12px}
.pagination button:hover{color:#409eff;border-color:#409eff}
.pagination button:disabled{color:#c0c4cc;cursor:not-allowed;border-color:#e4e7ed}
/* Search Form */
.search-bar{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;align-items:flex-end}
.search-bar .search-item{display:flex;flex-direction:column;gap:4px}
.search-bar .search-item label{font-size:12px;color:#909399}
.search-bar input,.search-bar select{padding:7px 10px;border:1px solid #d9d9d9;border-radius:4px;font-size:13px;outline:none;min-width:100px}
.search-bar input:focus,.search-bar select:focus{border-color:#667eea}
/* Toolbar */
.toolbar{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}
/* Modal */
.modal-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.45);z-index:1000;display:flex;align-items:center;justify-content:center}
.modal-box{background:#fff;border-radius:8px;width:90%;max-height:85vh;overflow-y:auto;box-shadow:0 12px 40px rgba(0,0,0,.2)}
.modal-box.sm{max-width:500px}
.modal-box.md{max-width:700px}
.modal-box.lg{max-width:900px}
.modal-box .modal-header{padding:16px 20px;border-bottom:1px solid #ebeef5;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:#fff;z-index:1}
.modal-box .modal-header h3{font-size:16px;font-weight:500}
.modal-box .modal-header .close{cursor:pointer;font-size:20px;color:#909399;line-height:1}
.modal-box .modal-header .close:hover{color:#333}
.modal-box .modal-body{padding:20px}
.modal-box .modal-footer{padding:12px 20px;border-top:1px solid #ebeef5;text-align:right;display:flex;gap:8px;justify-content:flex-end}
/* Form */
.form-group{margin-bottom:16px}
.form-group label{display:block;margin-bottom:6px;font-size:13px;color:#606266}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:8px 12px;border:1px solid #d9d9d9;border-radius:4px;font-size:13px;outline:none;transition:border .3s}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:#667eea}
.form-group textarea{resize:vertical;min-height:80px}
.form-row{display:flex;gap:16px;flex-wrap:wrap}
.form-row .form-group{flex:1;min-width:180px}
.form-section{font-weight:600;font-size:14px;color:#303133;margin:20px 0 10px;padding-bottom:6px;border-bottom:1px solid #ebeef5}
.form-hint{font-size:12px;color:#909399;margin-top:4px}
/* Tabs */
.tabs{display:flex;border-bottom:1px solid #ebeef5;margin-bottom:16px}
.tabs .tab{padding:10px 20px;cursor:pointer;font-size:14px;color:#909399;border-bottom:2px solid transparent;transition:all .3s}
.tabs .tab:hover{color:#409eff}
.tabs .tab.active{color:#409eff;border-bottom-color:#409eff}
/* Status Tags */
.status-tag{display:inline-block;padding:2px 10px;border-radius:4px;font-size:12px;font-weight:500;letter-spacing:0.3px}
.status-tag.green{background:#f0f9eb;color:#67c23a}
.status-tag.red{background:#fef0f0;color:#f56c6c}
.status-tag.orange{background:#fdf6ec;color:#e6a23c}
.status-tag.blue{background:#ecf5ff;color:#409eff}
.status-tag.gray{background:#f4f4f5;color:#909399}
/* Switch */
.switch{position:relative;display:inline-block;width:44px;height:22px;cursor:pointer}
.switch input{opacity:0;width:0;height:0}
.switch .slider{position:absolute;top:0;left:0;right:0;bottom:0;background:#c0c4cc;border-radius:22px;transition:.3s}
.switch .slider:before{content:'';position:absolute;height:18px;width:18px;left:2px;bottom:2px;background:#fff;border-radius:50%;transition:.3s}
.switch input:checked+.slider{background:#667eea}
.switch input:checked+.slider:before{transform:translateX(22px)}
/* Slot Grid */
.slot-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:8px;padding:10px}
.slot-item{padding:10px;text-align:center;border-radius:6px;cursor:pointer;font-size:12px;transition:all .2s}
.slot-item:hover{transform:scale(1.05)}
.slot-free{background:#f0f9eb;color:#67c23a;border:1px solid #c2e7b0}
.slot-used{background:#ecf5ff;color:#409eff;border:1px solid #b3d8ff}
.slot-fault{background:#fef0f0;color:#f56c6c;border:1px solid #fbc4c4}
.slot-locked{background:#f4f4f5;color:#909399;border:1px solid #d3d4d6}
.slot-item .num{font-size:18px;font-weight:600}
.slot-item .size{font-size:11px;margin-top:2px}
/* Toast */
.toast{position:fixed;top:20px;right:20px;z-index:9999;padding:12px 20px;border-radius:6px;color:#fff;font-size:14px;animation:slideIn .3s}
.toast.success{background:#67c23a}
.toast.error{background:#f56c6c}
.toast.warning{background:#e6a23c}
@keyframes slideIn{from{transform:translateX(100px);opacity:0}to{transform:translateX(0);opacity:1}}
/* Confirm */
.confirm-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.45);z-index:2000;display:flex;align-items:center;justify-content:center}
.confirm-box{background:#fff;border-radius:8px;padding:24px;width:90%;max-width:420px}
.confirm-box h3{margin-bottom:12px;font-size:16px}
.confirm-box p{margin-bottom:20px;color:#606266;font-size:14px;line-height:1.6}
.confirm-box .btns{display:flex;gap:8px;justify-content:flex-end}
/* Radio Group */
.radio-group{display:inline-flex;border:1px solid #d9d9d9;border-radius:4px;overflow:hidden}
.radio-group label{padding:6px 16px;cursor:pointer;font-size:13px;transition:all .2s;border-right:1px solid #d9d9d9}
.radio-group label:last-child{border-right:none}
.radio-group label:hover{background:#f5f7fa}
.radio-group input{display:none}
.radio-group input:checked+span{color:#fff}
.radio-group label:has(input:checked){background:#667eea;color:#fff}
/* Number Input */
.num-input{display:inline-flex;align-items:center;border:1px solid #d9d9d9;border-radius:4px;overflow:hidden}
.num-input button{width:28px;height:28px;border:none;background:#f5f7fa;cursor:pointer;font-size:16px}
.num-input button:hover{background:#e4e7ed}
.num-input input{width:60px;text-align:center;border:none;border-left:1px solid #d9d9d9;border-right:1px solid #d9d9d9;outline:none;height:28px;font-size:13px}
/* Chart */
.chart-box{background:#fff;border-radius:8px;padding:20px;margin-bottom:16px}
.chart-box h3{margin-bottom:12px;font-size:15px}
/* Responsive */
@media(max-width:768px){
/* sidebar always visible like desktop */
.content{padding:12px}
.stats-row{grid-template-columns:1fr 1fr}
.search-bar{flex-direction:column}
.search-bar .search-item{width:100%}
.modal-box{width:95%}
}
.sidebar-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:99}

/* Dropdown Menu */
.dropdown{position:relative;display:inline-block}
.dropdown-menu{position:absolute;right:0;top:100%;background:#fff;border-radius:6px;box-shadow:0 4px 16px rgba(0,0,0,.15);min-width:140px;z-index:9999;overflow:visible;margin-top:4px;border:1px solid #ebeef5}
.dropdown-item{padding:8px 16px;font-size:13px;cursor:pointer;white-space:nowrap;transition:background .2s}
.dropdown-item:hover{background:#f5f7fa}
.dropdown-item.danger{color:#f56c6c}
.dropdown-item.danger:hover{background:#fef0f0}
.dropdown-divider{height:1px;background:#ebeef5;margin:4px 0}
/* QR Code Modal */
.qr-modal-container{text-align:center;padding:20px}
.qr-info-card{background:linear-gradient(135deg,#f8f9ff 0%,#f0f7ff 100%);border-radius:12px;padding:20px;margin-bottom:20px}
.qr-info-item{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px dashed #d0d9e8}
.qr-info-item:last-child{border-bottom:none}
.qr-info-label{color:#606266;font-size:13px}
.qr-info-value{color:#303133;font-weight:500;font-size:13px}
.qr-image-wrapper{background:#fff;border-radius:12px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,.08);display:inline-block;margin:16px 0}
.qr-actions{display:flex;gap:12px;justify-content:center;margin-top:16px}

</style>
</head>
<body>
<div id="app">
<!-- Login -->
<div v-if="showLogin" class="login-bg">
<div class="login-card">
<h2>智能寄存柜管理后台</h2>
<div class="form-group"><label>用户名</label><input v-model="loginForm.username" placeholder="请输入用户名" @keyup.enter="$refs.pwdInput&&$refs.pwdInput.focus()"></div>
<div class="form-group"><label>密码</label><input ref="pwdInput" v-model="loginForm.password" type="password" placeholder="请输入密码" @keyup.enter="doLogin"></div>
<div class="form-group"><label>验证码</label>
<div class="captcha-row"><input v-model="loginForm.captcha" placeholder="请输入验证码" @keyup.enter="doLogin"><canvas id="captchaCanvas" width="120" height="40" @click="drawCaptcha"></canvas></div>
</div>
<button class="btn btn-primary" @click="doLogin" :disabled="loginLoading">{{loginLoading?'登录中...':'登 录'}}</button>
<div v-if="loginError" style="color:#f56c6c;margin-top:12px;font-size:13px">{{loginError}}</div>
</div>
</div>
<!-- Main Layout -->
<div v-else class="layout">
<sidebar></sidebar>
<div class="main">
<div class="topbar">
<span class="toggle" @click="isShrink=!isShrink">{{isShrink?'☰':'✕'}}</span>
<h1>{{currentTitle}}</h1>
<div class="spacer"></div>
<span class="user-menu" @click="activeMenu='change-pwd'">👤 {{adminUser}} <a href="#" @click.prevent="doLogout()" style="color:#f56c6c;font-size:12px;margin-left:8px">退出</a></span>
<span class="user-menu" style="margin-left:12px" @click="doLogout">退出</span>
</div>

<div class="modal-overlay" v-if="channelModal" @click.self="channelModal=false">
<div class="modal-box" style="max-width:500px">
<div class="modal-header"><h3>{{channelFormTitle}}</h3><span class="modal-close" @click="channelModal=false">&times;</span></div>
<div class="modal-body">
<div class="form-group"><label>渠道名称</label><input v-model="channelForm.name" placeholder="如：微信商户1"></div>
<div class="form-group"><label>渠道类型</label><select v-model="channelForm.channel_type"><option value="wechat">微信支付</option><option value="alipay">支付宝</option></select></div>
<div class="form-group"><label>商户号(mch_id)</label><input v-model="channelForm.mch_id" placeholder="微信支付商户号"></div>
<div class="form-group"><label>AppID</label><input v-model="channelForm.app_id" placeholder="公众号/小程序AppID"></div>
<div class="form-group"><label>API密钥</label><input v-model="channelForm.api_key" type="password" placeholder="支付API密钥"></div>
<div class="form-group"><label>AppSecret</label><input v-model="channelForm.app_secret" type="password" placeholder="AppSecret(微信需要)"></div>
</div>
<div class="modal-footer">
<button class="btn" @click="channelModal=false">取消</button>
<button class="btn btn-blue" @click="saveChannel()">保存</button>
</div>
</div>
</div>
<div class="content">
<component :is="'page-'+activeMenu"></component>
</div>
</div>
</div>
<!-- Toast -->
<div v-if="toastMsg" :class="'toast '+toastType">{{toastMsg}}</div>
<!-- Confirm -->
<div v-if="confirmVisible" class="confirm-mask">
<div class="confirm-box"><h3>提示</h3><p>{{confirmMsg}}</p><div class="btns"><button class="btn btn-sm" @click="confirmVisible=false">取消</button><button class="btn btn-sm btn-blue" @click="confirmCb&&confirmCb();confirmVisible=false">确定</button></div></div>
</div>

<!-- ========== Modals ========== -->

<!-- Cabinet Modal (设备编辑弹窗) -->
<div v-if="cabinetModal" class="modal-mask" @click.self="cabinetModal=false">
<div class="modal-box lg">
<div class="modal-header"><h3>{{cabinetFormTitle}}</h3><span class="close" @click="cabinetModal=false">×</span></div>
<div class="tabs"><span class="tab" :class="{active:cabinetEditTab==='basic'}" @click="cabinetEditTab='basic'">基本信息</span><span class="tab" :class="{active:cabinetEditTab==='basic2'}" @click="cabinetEditTab='basic2'">收费设置</span><span class="tab" :class="{active:cabinetEditTab==='basic3'}" @click="cabinetEditTab='basic3'">高级设置</span></div>
<div class="modal-body">
<!-- Basic Tab -->
<div v-if="cabinetEditTab==='basic'">
<div class="form-section">基础设备信息</div>
<div class="form-row">
<div class="form-group"><label>柜体编号</label><input v-model="cabinetForm.cabinet_code" placeholder="自动生成" :disabled="!!cabinetForm.id"></div>
<div class="form-group"><label>柜体名称</label><input v-model="cabinetForm.name" placeholder="如 1号柜"></div>
</div>
<div class="form-row">
<div class="form-group"><label>所属网点</label><select v-model="cabinetForm.location_id"><option value="">请选择</option><option v-for="l in locations" :value="l.id">{{l.name}}</option></select></div>
<div class="form-group"><label>设备类型</label><select v-model="cabinetForm.device_type"><option value="screen">屏幕柜</option><option value="barcode">条码柜</option></select></div>
</div>
<div class="form-row">
<div class="form-group"><label>柜门数量</label><input type="number" v-model="cabinetForm.total_slots" min="1" max="100"></div>
<div class="form-group"><label>营业状态</label><div class="radio-group"><label :class="{active:cabinetForm.business_status==='open'}"><input type="radio" v-model="cabinetForm.business_status" value="open"><span>营业中</span></label><label :class="{active:cabinetForm.business_status==='closed'}"><input type="radio" v-model="cabinetForm.business_status" value="closed"><span>已停业</span></label></div></div>
</div>
<div class="form-section">主板匹配信息</div>
<div class="form-row">
<div class="form-group"><label>主板ID</label><input v-model="cabinetForm.mainboard_device_id" placeholder="工业屏APK匹配的设备ID"></div>
<div class="form-group"><label>主板来源</label><select v-model="cabinetForm.mainboard_source"><option value="WT">WT(威特)</option><option value="YBM">YBM(亚博明)</option></select></div>
</div>
<div class="form-row">
<div class="form-group"><label>设备状态</label><div class="radio-group"><label :class="{active:cabinetForm.status===1}"><input type="radio" v-model="cabinetForm.status" :value="1"><span>启用</span></label><label :class="{active:cabinetForm.status===0}"><input type="radio" v-model="cabinetForm.status" :value="0"><span>停用</span></label></div></div>
</div>
<div class="form-section">物联网卡信息</div>
<div class="form-row">
<div class="form-group"><label>物联网卡公司</label><input v-model="cabinetForm.iot_company" placeholder="如 中国移动"></div>
<div class="form-group"><label>物联网卡卡号</label><input v-model="cabinetForm.iot_iccid" placeholder="ICCID卡号"></div>
</div>
</div>
<!-- Basic2 Tab (收费设置) -->
<div v-if="cabinetEditTab==='basic2'">
<div class="form-section">收费设置</div>
<div class="form-group"><label>收费模式</label><select v-model="cabinetForm.charge_mode"><option value="free">免费</option><option value="deposit">保证金</option><option value="per_use">按次收费</option></select></div>
<template v-if="cabinetForm.charge_mode==='deposit'">
<div class="form-row">
<div class="form-group"><label>保证金金额(元)</label><input type="number" v-model="cabinetForm.deposit_amount" min="0"></div>
<div class="form-group"><label>超时时间(小时)</label><input type="number" v-model="cabinetForm.deposit_timeout" min="1" max="168"></div>
</div>
</template>
<template v-if="cabinetForm.charge_mode==='per_use'">
<div class="form-row">
<div class="form-group"><label>每次收费(元)</label><input type="number" v-model="cabinetForm.per_use_price" min="0" placeholder="如8元一次填8"></div>
<div class="form-group"><label>保证金(元)</label><input type="number" v-model="cabinetForm.deposit_amount" min="0" placeholder="寄存时一起收取，取包后退"></div>
</div>
<div class="form-group"><label>超时时间(小时)</label><input type="number" v-model="cabinetForm.deposit_timeout" min="1" max="168"></div>
</template>
<div class="form-section">定时清空</div>
<div class="form-group"><label class="switch-label">启用定时清空</label><label class="switch"><input type="checkbox" v-model="cabinetForm.clean_balance_enabled"><span class="slider"></span></label></div>
<template v-if="cabinetForm.clean_balance_enabled">
<div class="form-row">
<div class="form-group"><label>任务时间</label><input type="time" v-model="cabinetForm.clean_balance_time"></div>
<div class="form-group"><label>清空周期(天)</label><input type="number" v-model="cabinetForm.clean_balance_period" min="1"></div>
</div>
</template>
</div>
<!-- Basic3 Tab (高级设置) -->
<div v-if="cabinetEditTab==='basic3'">
<div class="form-section">其他设置</div>
<div class="form-row">
<div class="form-group"><label>客服电话</label><input v-model="cabinetForm.customer_phone" placeholder="客服联系电话"></div>
<div class="form-group"><label>客户电话</label><input v-model="cabinetForm.merchant_phone" placeholder="商户联系电话"></div>
</div>
<div class="form-group"><label>寄存规则</label><textarea v-model="cabinetForm.usage_rules" rows="4" placeholder="每行一条规则，留空使用默认规则" style="width:100%;padding:6px 10px;border:1px solid #dcdfe6;border-radius:4px;resize:vertical"></textarea></div>
<div class="form-group"><label>备注</label><textarea v-model="cabinetForm.remark" rows="3" placeholder="其他备注信息"></textarea></div>
</div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="cabinetModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveCabinet">保存</button></div>
</div>
</div>

<!-- Location Modal (网点编辑弹窗) -->
<div v-if="locationModal" class="modal-mask" @click.self="locationModal=false">
<div class="modal-box md">
<div class="modal-header"><h3>{{locationFormTitle}}</h3><span class="close" @click="locationModal=false">×</span></div>
<div class="tabs"><span class="tab" :class="{active:locationEditTab==='basic'}" @click="locationEditTab='basic'">基本信息</span><span class="tab" :class="{active:locationEditTab==='basic2'}" @click="locationEditTab='basic2'">营业设置</span><span class="tab" :class="{active:locationEditTab==='basic3'}" @click="locationEditTab='basic3'">高级设置</span></div>
<div class="modal-body">
<!-- Basic Tab -->
<div v-if="locationEditTab==='basic'">
<div class="form-group"><label>网点名称</label><input v-model="locationForm.name" placeholder="请输入网点名称"></div>
<div class="form-group"><label>详细地址</label><input v-model="locationForm.address" placeholder="请输入详细地址"></div>
<div class="form-row">
<div class="form-group"><label>经度</label><input v-model="locationForm.longitude" placeholder="经度"></div>
<div class="form-group"><label>纬度</label><input v-model="locationForm.latitude" placeholder="纬度"></div>
</div>
<div class="form-group"><label>所属商家</label><select v-model="locationForm.merchant_id"><option value="">请选择</option><option v-for="m in merchants" :value="m.id">{{m.name}}</option></select></div>
<div class="form-row">
<div class="form-group"><label>联系人</label><input v-model="locationForm.contact_name" placeholder="联系人"></div>
<div class="form-group"><label>联系电话</label><input v-model="locationForm.contact_phone" placeholder="联系电话"></div>
</div>
<div class="form-group"><label>状态</label><div class="radio-group"><label :class="{active:locationForm.status===1}"><input type="radio" v-model="locationForm.status" :value="1"><span>启用</span></label><label :class="{active:locationForm.status===0}"><input type="radio" v-model="locationForm.status" :value="0"><span>停用</span></label></div></div>

<!-- Basic2 Tab (营业设置) -->
<div v-if="locationEditTab==='basic2'">
<div class="form-section">营业时间</div>
<div class="form-row">
<div class="form-group"><label>开始时间</label><input type="time" v-model="locationForm.open_time"></div>
<div class="form-group"><label>结束时间</label><input type="time" v-model="locationForm.close_time"></div>
</div>
<div class="form-section">柜门设置</div>
<div class="form-group"><label>允许用户选择柜门</label><label class="switch"><input type="checkbox" v-model="locationForm.allow_slot_select"><span class="slider"></span></label></div>
<div class="form-group"><label>分配模式</label><select v-model="locationForm.slot_assign_mode"><option value="auto">自动分配</option><option value="fixed">指定柜门</option></select></div>
<div class="form-group"><label>中途取物</label><label class="switch"><input type="checkbox" v-model="locationForm.allow_mid_retrieve"><span class="slider"></span></label></div>
<div class="form-group"><label>取包模式</label><select v-model="locationForm.retrieve_mode"><option value="scan_only">仅扫码</option><option value="password_only">仅密码</option><option value="both">两者均可</option></select></div>
</div>
<!-- Basic3 Tab (高级设置) -->
<div v-if="locationEditTab==='basic3'">
<div class="form-section">H5与二维码设置</div>
<div class="form-group"><label>扫码跳转小程序</label><label class="switch"><input type="checkbox" v-model="locationForm.allow_h5_to_mp"><span class="slider"></span></label></div>
<div class="form-group"><label>关注二维码</label><label class="switch"><input type="checkbox" v-model="locationForm.show_qr_follow"><span class="slider"></span></label></div>
<div class="form-group"><label>强制关注</label><label class="switch"><input type="checkbox" v-model="locationForm.force_follow_mp"><span class="slider"></span></label></div>
<template v-if="locationForm.allow_h5_to_mp">
<div class="form-group"><label style="color:#67c23a">已开启：扫码后自动跳转用户端小程序</label></div>
</template>
<div class="form-section">屏幕显示设置</div>
<div class="form-group"><label>显示柜门数量</label><label class="switch"><input type="checkbox" v-model="locationForm.show_slot_count"><span class="slider"></span></label></div>
<div class="form-group"><label>屏幕标题</label><label class="switch"><input type="checkbox" v-model="locationForm.screen_show_title"><span class="slider"></span></label></div>
<template v-if="locationForm.screen_show_title">
<div class="form-group"><label>自定义标题</label><input v-model="locationForm.screen_title" placeholder="请输入屏幕标题"></div>
</template>
</div>
</div>
<div class="form-section">提现与退款审批模式</div>
<div class="form-group"><label>允许提现</label><label class="switch"><input type="checkbox" v-model="locationForm.withdraw_enabled"><span class="slider"></span></label></div>
<div class="form-group"><label>显示退款中状态</label><label class="switch"><input type="checkbox" v-model="locationForm.show_refunding_status"><span class="slider"></span></label></div>
<div class="form-group" v-if="locationForm.withdraw_enabled"><label>审批模式</label><select v-model="locationForm.withdraw_mode"><option value="manual_approve">手动审批</option><option value="queue_approve">列队审批</option><option value="auto_approve">自动审批</option></select></div>
<template v-if="locationForm.withdraw_enabled&&locationForm.withdraw_mode==='manual_approve'">
<div class="form-group"><label>审批天数(第几天审批)</label><input type="number" v-model="locationForm.auto_approve_day" placeholder="7"></div>
<div class="form-group"><label>审批时间</label><input type="time" v-model="locationForm.auto_approve_time"></div>
<div class="form-group"><label>审批通过率(%)</label><input type="number" v-model="locationForm.auto_approve_rate" placeholder="80"></div>
</template>
<template v-if="locationForm.withdraw_enabled&&locationForm.withdraw_mode==='queue_approve'">
<div class="form-group"><label>审批起始(分钟)</label><input type="number" v-model="locationForm.refund_approve_start_min" placeholder="60"></div>
<div class="form-group"><label>审批截止(分钟)</label><input type="number" v-model="locationForm.refund_approve_end_min" placeholder="300"></div>
<div class="form-group"><label>审批通过率(%)</label><input type="number" v-model="locationForm.refund_approve_rate" placeholder="80"></div>
</template>
<template v-if="locationForm.withdraw_enabled&&locationForm.withdraw_mode==='auto_approve'">
<div style="color:#67c23a;font-size:13px;padding:8px 0">用户提现后自动退款，无需等待审批</div>
</template>
<div class="form-group"><label>免费次数</label><input type="number" v-model="locationForm.click_free_count" placeholder="3"></div>
<div class="form-section">防刷配置</div>
<div class="form-group"><label>防刷时间(分钟)</label><input type="number" v-model="locationForm.anti_test_minutes" placeholder="30"></div>
<div class="form-group"><label>防刷自动退款</label><label class="switch"><input type="checkbox" v-model="locationForm.anti_test_auto_refund"><span class="slider"></span></label></div>
<div class="form-section">订单可见性</div>
<div class="form-group"><label>隐藏比例(%)</label><input type="number" v-model="locationForm.hide_ratio" placeholder="0"></div>
<div class="form-group"><label>白名单手机号</label><input v-model="locationForm.whitelist_phones" placeholder="多个用英文逗号分隔"></div>
<div class="form-section">重复过滤</div>
<div class="form-group"><label>启用重复过滤</label><label class="switch"><input type="checkbox" v-model="locationForm.duplicate_filter_enabled"><span class="slider"></span></label></div>
<div class="form-group"><label>过滤天数</label><input type="number" v-model="locationForm.duplicate_filter_days" placeholder="7"></div>
<div class="form-group"><label>过滤次数</label><input type="number" v-model="locationForm.duplicate_filter_limit" placeholder="3"></div>
<div class="modal-footer"><button class="btn btn-sm" @click="locationModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveLocation">保存</button></div>
</div>
</div>

<!-- Order Detail Modal -->
<div v-if="orderDetailModal" class="modal-mask" @click.self="orderDetailModal=false">
<div class="modal-box md">
<div class="modal-header"><h3>订单详情</h3><span class="close" @click="orderDetailModal=false">×</span></div>
<div class="modal-body" v-if="orderDetail">
<table style="margin-bottom:16px"><tr><td style="padding:6px 12px;border:1px solid #ebeef5;width:50%"><strong>订单号：</strong>{{orderDetail.order_no||'-'}}</td><td style="padding:6px 12px;border:1px solid #ebeef5;width:50%"><strong>用户手机：</strong>{{orderDetail.user_phone||'-'}}</td></tr><tr><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>柜体编号：</strong>{{orderDetail.cabinet_code||orderDetail.cabinet_name||'-'}}</td><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>柜格号：</strong>{{orderDetail.compartment_number||'-'}}</td></tr><tr><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>保证金：</strong>¥{{orderDetail.deposit_amount||0}}</td><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>退款金额：</strong>¥{{orderDetail.refund_amount||0}}</td></tr><tr><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>状态：</strong><span :class="'status-tag '+statusClass(orderDetail.status)">{{statusText(orderDetail.status)}}</span></td><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>密码：</strong>{{orderDetail.password||'-'}}</td></tr><tr><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>存包时间：</strong>{{orderDetail.store_time||'-'}}</td><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>取包时间：</strong>{{orderDetail.retrieve_time||'-'}}</td></tr></table>
</div>
<div class="modal-footer"><button class="btn btn-sm btn-primary" @click="orderOpenDoor" style="margin-right:8px;background:#409eff;color:#fff">开门</button><button class="btn btn-sm" @click="orderDetailModal=false">关闭</button></div>
</div>
</div>

<!-- Agent Modal -->
<div v-if="agentModal" class="modal-mask" @click.self="agentModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>{{agentFormTitle}}</h3><span class="close" @click="agentModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>代理商名称</label><input v-model="agentForm.name" placeholder="请输入代理商名称"></div>
<div class="form-group"><label>联系人</label><input v-model="agentForm.contact_name" placeholder="请输入联系人"></div>
<div class="form-group"><label>联系电话</label><input v-model="agentForm.contact_phone" placeholder="请输入联系电话"></div>
<div class="form-group"><label>登录密码</label><input type="password" v-model="agentForm.password" placeholder="请输入密码(新增时必填)"></div>
<div class="form-group"><label>抽成比例(%)</label><input v-model.number="agentForm.commission_rate" type="number" min="0" max="100" step="0.1" placeholder="如5表示5%"></div>
<div class="form-group"><label>状态</label><div class="radio-group"><label :class="{active:agentForm.status===1}"><input type="radio" v-model="agentForm.status" :value="1"><span>正常</span></label><label :class="{active:agentForm.status===0}"><input type="radio" v-model="agentForm.status" :value="0"><span>停用</span></label></div></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="agentModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveAgent">保存</button></div>
</div>
</div>

<!-- Merchant Modal -->
<div v-if="merchantModal" class="modal-mask" @click.self="merchantModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>{{merchantFormTitle}}</h3><span class="close" @click="merchantModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>所属代理商</label><select v-model="merchantForm.agent_id"><option value="">请选择代理商</option><option v-for="a in agents" :value="a.id">{{a.name}}</option></select></div>
<div class="form-group"><label>商家名称</label><input v-model="merchantForm.name" placeholder="请输入商家名称"></div>
<div class="form-group"><label>联系人</label><input v-model="merchantForm.contact_name" placeholder="请输入联系人"></div>
<div class="form-group"><label>联系电话</label><input v-model="merchantForm.contact_phone" placeholder="请输入联系电话"></div>
<div class="form-group"><label>登录密码</label><input type="password" v-model="merchantForm.password" placeholder="请输入密码(新增时必填)"></div>
<div class="form-group"><label>状态</label><div class="radio-group"><label :class="{active:merchantForm.status===1}"><input type="radio" v-model="merchantForm.status" :value="1"><span>正常</span></label><label :class="{active:merchantForm.status===0}"><input type="radio" v-model="merchantForm.status" :value="0"><span>停用</span></label></div></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="merchantModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveMerchant">保存</button></div>
</div>
</div>

<!-- Employee Modal -->
<div v-if="employeeModal" class="modal-mask" @click.self="employeeModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>{{employeeFormTitle}}</h3><span class="close" @click="employeeModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>所属商家</label><select v-model="employeeForm.merchant_id"><option value="">请选择商家</option><option v-for="m in merchants" :value="m.id">{{m.name}}</option></select></div>
<div class="form-group"><label>员工姓名</label><input v-model="employeeForm.name" placeholder="请输入员工姓名"></div>
<div class="form-group"><label>手机号</label><input v-model="employeeForm.phone" placeholder="请输入手机号"></div>
<div class="form-group"><label>登录密码</label><input type="password" v-model="employeeForm.password" placeholder="请输入密码(新增时必填)"></div>
<div class="form-group"><label>角色</label><select v-model="employeeForm.role"><option value="admin">管理员</option><option value="operator">操作员</option></select></div>
<div class="form-group"><label>状态</label><div class="radio-group"><label :class="{active:employeeForm.status===1}"><input type="radio" v-model="employeeForm.status" :value="1"><span>正常</span></label><label :class="{active:employeeForm.status===0}"><input type="radio" v-model="employeeForm.status" :value="0"><span>停用</span></label></div></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="employeeModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveEmployee">保存</button></div>
</div>
</div>

<!-- User Modal -->
<div v-if="userModal" class="modal-mask" @click.self="userModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>{{userFormTitle}}</h3><span class="close" @click="userModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>用户名</label><input v-model="userForm.username" placeholder="请输入用户名"></div>
<div class="form-group"><label>密码</label><input type="password" v-model="userForm.password" placeholder="请输入密码(新增时必填)"></div>
<div class="form-group"><label>角色</label><select v-model="userForm.role"><option value="admin">管理员</option><option value="operator">操作员</option></select></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="userModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveUser">保存</button></div>
</div>
</div>

<!-- APK Modal -->
<div v-if="apkModal" class="modal-mask" @click.self="apkModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>发布APK版本</h3><span class="close" @click="apkModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>版本名称</label><input v-model="apkForm.version_name" placeholder="如 v1.1.0"></div>
<div class="form-group"><label>版本号(整数)</label><input type="number" v-model="apkForm.version_code" placeholder="如 110"></div>
<div class="form-group"><label>下载地址</label><input v-model="apkForm.download_url"></div>
<div class="form-group"><label>更新说明</label><textarea v-model="apkForm.update_desc" rows="3"></textarea></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="apkModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveApkVersion">发布</button></div>
</div>
</div>

<!-- Mainboard Modal -->
<div v-if="mainboardModal" class="modal-mask" @click.self="mainboardModal=false">
<div class="modal-box">
<div class="modal-header"><h3>主板管理 - {{cabinetForm.cabinet_code||cabinetForm.name}}</h3><span class="close" @click="mainboardModal=false">×</span></div>
<div class="modal-body">
<div v-if="mainboardsList.length" style="margin-bottom:16px">
<table style="width:100%;font-size:13px"><tr><th>板号</th><th>协议</th><th>串口</th><th>波特率</th><th>柜门数</th><th>操作</th></tr>
<tr v-for="mb in mainboardsList" :key="mb.id"><td style="text-align:center">{{mb.board_index}}</td><td style="text-align:center">{{mb.protocol}}</td><td style="text-align:center">{{mb.serial_port}}</td><td style="text-align:center">{{mb.baud_rate}}</td><td style="text-align:center">{{mb.slot_count}}</td><td style="text-align:center"><button class="btn btn-sm" style="background:#4FC3F7;color:#000;border:none;border-radius:4px" @click="editMainboard(mb)">编辑</button> <button class="btn btn-sm" style="background:#E57373;color:#000;border:none;border-radius:4px" @click="deleteMainboard(mb)">删除</button></td></tr>
</table>
<button class="btn btn-sm btn-blue" @click="generateSlots" style="margin-top:8px">根据主板生成柜格</button>
<hr style="margin:12px 0;border-color:#ebeef5">
</div>
<div class="form-section">{{mainboardForm.id?'编辑主板':'添加主板'}}</div>
<div class="form-group"><label>板号</label><input type="number" v-model="mainboardForm.board_index" min="1" max="20"></div>
<div class="form-group"><label>类型</label><select v-model="mainboardForm.board_type"><option value="main">主控板</option><option value="extension">扩展板</option></select></div>
<div class="form-group"><label>串口</label><select v-model="mainboardForm.serial_port"><option value="ttyS1">ttyS1</option><option value="ttyS2">ttyS2</option><option value="ttyS3">ttyS3</option><option value="ttyS4">ttyS4</option></select></div>
<div class="form-group"><label>波特率</label><select v-model="mainboardForm.baud_rate"><option :value="9600">9600</option><option :value="115200">115200</option></select></div>
<div class="form-group"><label>协议</label><select v-model="mainboardForm.protocol"><option value="YBM">YBM(亚博明)</option><option value="WT">WT(威特)</option></select></div>
<div class="form-group"><label>地址</label><input v-model="mainboardForm.address" placeholder="如 01"></div>
<div class="form-group"><label>柜门数</label><input type="number" v-model="mainboardForm.slot_count" min="1" max="60"></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" style="margin-right:auto" @click="generateSlots">生成柜格</button><button class="btn btn-sm" @click="mainboardModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveMainboard">确认</button></div>
</div>
</div>

<!-- Slot Grid Modal -->
<div v-if="slotModal" class="modal-mask" @click.self="slotModal=false">
<div class="modal-box md">
<div class="modal-header"><h3>柜门管理 - {{cabinetForm.cabinet_code}}</h3><span class="close" @click="slotModal=false">&times;</span></div>
<div class="modal-body">
<div style="margin-bottom:12px"><button class="btn btn-sm btn-orange" @click="batchOpenSlots2()">批量开门</button> <button class="btn btn-sm btn-red" @click="clearAllSlots2()">清柜</button> <button class="btn btn-sm" style="background:#4FC3F7;color:#000;border:none;border-radius:4px" @click="batchSetSlotStatus()">批量改状态</button> <button class="btn btn-sm" style="background:#E57373;color:#000;border:none;border-radius:4px" @click="batchDeleteSelected">批量删除</button> <button class="btn btn-sm" style="background:#9575CD;color:#fff;border:none;border-radius:4px" @click="toggleSelectAllSlots()">{{selectedSlotIds.length===slots.length?"取消全选":"全选"}}</button> <button class="btn btn-sm btn-blue" @click="showAddSlotModal()">添加柜门</button></div>
<div class="slot-grid">
<div v-for="s in slotGridData" :key="s.id" @click="openSingleSlot(s)" :style="{width:'72px',height:'72px',borderRadius:'8px',display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',cursor:'pointer',fontWeight:'bold',fontSize:'13px',background:s.status===1?'#e8f5e9':s.status===2?'#fff3e0':s.status===3?'#ffebee':'#f0f0f0',border:s.status===1?'2px solid #67c23a':s.status===2?'2px solid #e6a23c':s.status===3?'2px solid #f56c6c':'2px solid #909399'}">
<span>{{s.slot_number}}</span>
<span style="font-size:11px;font-weight:normal">{{s.status===1?'空闲':s.status===2?'占用':s.status===3?'故障':'锁定'}}</span>
</div>
</div>
<div style="margin-top:8px;color:#909399;font-size:12px">空闲/故障=点击编辑 | 占用=点击开门</div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="slotModal=false">关闭</button></div>
</div>
</div>

<!-- Slot Edit Modal -->
<div v-if="slotEditModal" class="modal-mask" @click.self="slotEditModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>编辑柜格</h3><span class="close" @click="slotEditModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>柜格号</label><input :value="slotEditForm.slot_number" disabled></div>
<div class="form-group"><label>柜格大小</label><select v-model="slotEditForm.slot_size"><option value="small">小柜</option><option value="medium">中柜</option><option value="large">大柜</option></select></div>
<div class="form-group"><label>状态</label><select v-model="slotEditForm.status"><option :value="1">空闲</option><option :value="2">使用中</option><option :value="3">故障</option><option :value="4">锁定</option></select></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="slotEditModal=false">取消</button><button class="btn btn-sm btn-red" @click="deleteSlot">删除</button><button class="btn btn-sm btn-blue" @click="saveSlotEdit">保存</button></div>
</div>
</div>

<!-- Add Slot Modal -->
<div v-if="addSlotModal" class="modal-mask" @click.self="addSlotModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>添加柜门</h3><span class="close" @click="addSlotModal=false">&times;</span></div>
<div class="modal-body">
<div class="form-group"><label>柜门大小</label><select v-model="addSlotForm.slot_size" style="width:100%;padding:6px 10px;border:1px solid #dcdfe6;border-radius:4px"><option value="small">小柜</option><option value="medium">中柜</option><option value="large">大柜</option></select></div>
<div class="form-group"><label>主板号</label><input v-model="addSlotForm.board_no" type="number" min="1" max="4" placeholder="1=一号主板 2=二号主板" style="width:100%;padding:6px 10px;border:1px solid #dcdfe6;border-radius:4px"><p style="font-size:12px;color:#999;margin-top:4px">选择该批柜门所属主板</p></div>
<div class="form-group"><label>柜门数</label><input v-model="addSlotForm.slot_count" type="number" min="1" max="60" placeholder="填24则生成24个柜门" style="width:100%;padding:6px 10px;border:1px solid #dcdfe6;border-radius:4px"><p style="font-size:12px;color:#999;margin-top:4px">自动接续已有编号，如已有1-24号填24则生成25-48号</p></div>
</div>
<div class="modal-footer"><button class="btn btn-sm btn-blue" @click="saveAddSlot()">保存</button> <button class="btn btn-sm" @click="addSlotModal=false">取消</button></div>
</div>
</div>

<!-- Member Detail Modal -->
<div v-if="memberDetailModal" class="modal-mask" @click.self="memberDetailModal=false">
<div class="modal-box md">
<div class="modal-header"><h3>会员详情</h3><span class="close" @click="memberDetailModal=false">×</span></div>
<div class="modal-body" v-if="memberDetail">
<table style="margin-bottom:16px"><tr><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>手机号：</strong>{{memberDetail.phone||'-'}}</td><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>押金余额：</strong>¥{{memberDetail.balance||0}}</td></tr><tr><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>累计存入：</strong>¥{{memberDetail.total_deposit||0}}</td><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>累计提现：</strong>¥{{memberDetail.total_withdraw||0}}</td></tr><tr><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>首次使用：</strong>{{memberDetail.first_use_time||'-'}}</td><td style="padding:6px 12px;border:1px solid #ebeef5"><strong>最后使用：</strong>{{memberDetail.last_use_time||'-'}}</td></tr></table>
<h4 style="margin-bottom:10px">最近订单</h4>
<table><tr><th>订单号</th><th>存包时间</th><th>状态</th></tr><tr v-for="o in (memberDetail.recent_orders||[])"><td>{{o.order_no||'-'}}</td><td>{{o.store_time||'-'}}</td><td><span :class="'status-tag '+statusClass(o.status)">{{statusText(o.status)}}</span></td></tr><tr v-if="!(memberDetail.recent_orders||[]).length"><td colspan="3" style="text-align:center;color:#909399;padding:20px">暂无订单</td></tr></table>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="memberDetailModal=false">关闭</button></div>
</div>
</div>

<!-- Complaint Reply Modal -->
<div v-if="complaintReplyModal" class="modal-mask" @click.self="complaintReplyModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>回复投诉</h3><span class="close" @click="complaintReplyModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>投诉内容</label><div style="color:#666;padding:8px 0">{{complaintReplyForm.content||'-'}}</div></div>
<div class="form-group"><label>回复内容</label><textarea v-model="complaintReplyForm.reply" rows="4" placeholder="请输入回复内容"></textarea></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="complaintReplyModal=false">取消</button><button class="btn btn-sm btn-blue" @click="submitComplaintReply">提交回复</button></div>
</div>
</div>

<!-- Reject Modal (拒绝提现) -->
<div v-if="rejectModal" class="modal-mask" @click.self="rejectModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>拒绝提现</h3><span class="close" @click="rejectModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>提现金额</label><div style="padding:8px 0;font-size:16px">¥{{rejectForm.amount||0}}</div></div>
<div class="form-group"><label>拒绝原因</label><textarea v-model="rejectForm.reason" rows="3" placeholder="请输入拒绝原因"></textarea></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="rejectModal=false">取消</button><button class="btn btn-sm btn-blue" @click="submitReject">确认拒绝</button></div>
</div>
</div>

<!-- AfterSales Modal (售后工单) -->
<div v-if="afterSalesModal" class="modal-mask" @click.self="afterSalesModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>{{afterSalesFormTitle}}</h3><span class="close" @click="afterSalesModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>关联设备</label><select v-model="afterSalesForm.cabinet_id"><option value="">请选择设备</option><option v-for="m in machines" :value="m.id">{{m.cabinet_code||m.name}}</option></select></div>
<div class="form-group"><label>故障类型</label><select v-model="afterSalesForm.type"><option value="hardware">硬件故障</option><option value="software">软件故障</option><option value="network">网络问题</option><option value="other">其他</option></select></div>
<div class="form-group"><label>故障描述</label><textarea v-model="afterSalesForm.description" rows="4" placeholder="请输入故障描述"></textarea></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="afterSalesModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveAfterSales">保存</button></div>
</div>
</div>

<!-- AfterSales Handle Modal -->
<div v-if="afterSalesHandleModal" class="modal-mask" @click.self="afterSalesHandleModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>处理工单</h3><span class="close" @click="afterSalesHandleModal=false">×</span></div>
<div class="modal-body">
<div class="form-group"><label>工单号</label><div style="padding:8px 0">{{afterSalesHandleForm.ticket_no||'-'}}</div></div>
<div class="form-group"><label>故障类型</label><div style="padding:8px 0">{{afterSalesHandleForm.type||'-'}}</div></div>
<div class="form-group"><label>故障描述</label><div style="padding:8px 0">{{afterSalesHandleForm.description||'-'}}</div></div>
<div class="form-group"><label>处理状态</label><select v-model="afterSalesHandleForm.status"><option value="pending">待处理</option><option value="processing">处理中</option><option value="resolved">已解决</option></select></div>
<div class="form-group"><label>处理说明</label><textarea v-model="afterSalesHandleForm.handler_note" rows="3" placeholder="请输入处理说明"></textarea></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="afterSalesHandleModal=false">取消</button><button class="btn btn-sm btn-blue" @click="submitAfterSalesHandle">提交</button></div>
</div>
</div>
<!-- Device Detail Modal -->
<div v-if="deviceDetailModal" class="modal-mask" @click.self="deviceDetailModal=false">
<div class="modal-box lg">
<div class="modal-header"><h3>设备详情 - {{deviceDetail.cabinet_code}}</h3><span class="close" @click="deviceDetailModal=false">&times;</span></div>
<div class="modal-body" v-if="deviceDetail">
<div style="display:flex;justify-content:space-between;margin-bottom:16px">
<div><strong>状态：</strong><span :class="'status-tag '+(deviceDetail.is_online?'green':'gray')">{{deviceDetail.is_online?'在线':'离线'}}</span></div>
<div><strong>APK：</strong>{{deviceDetail.app_version||'-'}}</div>
<div><button class="btn btn-sm btn-orange" @click="batchOpenSlots(deviceDetail)">批量开门</button> <button class="btn btn-sm btn-red" @click="clearAllSlots(deviceDetail)">清柜</button> <button class="btn btn-sm" style="background:#4FC3F7;color:#000;border:none;border-radius:4px" @click="showDeviceQrcode(deviceDetail)">二维码</button></div>
</div>
<div class="form-section">柜门状态</div>
<div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px">
<div v-for="s in deviceDetail.slots" :key="s.id" @click="s.status===2?openSingleSlot(s):updateSlotStatus(s)" :style="{width:'52px',height:'52px',borderRadius:'8px',display:'flex',alignItems:'center',justifyContent:'center',cursor:'pointer',fontWeight:'bold',fontSize:'14px',background:s.status===1?'#e8f5e9':s.status===2?'#fff3e0':'#ffebee',border:s.status===1?'2px solid #67c23a':s.status===2?'2px solid #e6a23c':'2px solid #f56c6c'}">
{{s.slot_number}}
</div>
</div>
<div style="font-size:12px;color:#909399;margin-bottom:16px">
<span style="display:inline-block;width:12px;height:12px;background:#e8f5e9;border:1px solid #67c23a;border-radius:3px;margin-right:4px;vertical-align:middle"></span>空闲
<span style="display:inline-block;width:12px;height:12px;background:#fff3e0;border:1px solid #e6a23c;border-radius:3px;margin:0 4px 0 12px;vertical-align:middle"></span>占用
<span style="display:inline-block;width:12px;height:12px;background:#ffebee;border:1px solid #f56c6c;border-radius:3px;margin:0 4px 0 12px;vertical-align:middle"></span>故障
<span style="margin-left:16px">占用=开门, 空闲/故障=切换状态</span>
</div>
<div class="form-section" v-if="deviceDetail.active_orders&&deviceDetail.active_orders.length">活跃订单 ({{deviceDetail.active_orders.length}})</div>
<table v-if="deviceDetail.active_orders&&deviceDetail.active_orders.length">
<tr><th>订单号</th><th>柜格</th><th>手机</th><th>金额</th><th>存包时间</th></tr>
<tr v-for="o in deviceDetail.active_orders"><td>{{o.order_no}}</td><td>{{o.compartment_number||'-'}}</td><td>{{o.user_phone||'-'}}</td><td>&#165;{{o.deposit_amount||0}}</td><td>{{o.store_time||'-'}}</td></tr>
</table>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="deviceDetailModal=false">关闭</button></div>
</div>
</div>


<!-- Device QR Code Modal -->
<div v-if="deviceQrcodeModal" class="modal-mask" id="deviceQrcodeModal" @click.self="deviceQrcodeModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>设备二维码 - {{deviceQrcode&&deviceQrcode.cabinet_code}}</h3><span class="close" @click="deviceQrcodeModal=false">&times;</span></div>
<div class="modal-body" v-if="deviceQrcode" style="text-align:center;padding:24px">
<div style="margin-bottom:16px">
<p style="font-size:14px;font-weight:600;margin-bottom:12px">ID: {{deviceQrcode.id}} | {{deviceQrcode.cabinet_code}}</p><img :src="deviceQrcode.qrcode_img" style="width:200px;height:200px" v-if="deviceQrcode.qrcode_img">
</div>
<p style="font-size:12px;color:#67c23a;word-break:break-all;margin-bottom:16px">{{deviceQrcode.qr_url}}</p>
<button class="btn btn-sm btn-blue" @click="downloadDeviceQrcode" style="margin-right:8px">下载二维码</button>
<button class="btn btn-sm" @click="deviceQrcodeModal=false">关闭</button>
</div>
</div>
</div>


<!-- Cabinet Group Modal -->
<div v-if="cabinetGroupModal" class="modal-mask" @click.self="cabinetGroupModal=false">
<div class="modal-box sm">
<div class="modal-header"><h3>{{cabinetGroupForm.id?'编辑柜组':'新增柜组'}}</h3><span class="close" @click="cabinetGroupModal=false">&times;</span></div>
<div class="modal-body">
<div class="form-group"><label>柜组名称</label><input v-model="cabinetGroupForm.name" placeholder="请输入柜组名称"></div>
<div class="form-group"><label>所属网点</label><select v-model="cabinetGroupForm.location_id"><option value="">请选择网点</option><option v-for="l in locations" :value="l.id">{{l.name}}</option></select></div>
<div class="form-group" v-if="!cabinetGroupForm.id"><label>柜组编号</label><input v-model="cabinetGroupForm.group_code" placeholder="留空自动生成"></div>
<div class="form-group"><label>屏幕地址</label><input v-model="cabinetGroupForm.screen_url" placeholder="可选"></div>
</div>
<div class="modal-footer"><button class="btn btn-sm" @click="cabinetGroupModal=false">取消</button><button class="btn btn-sm btn-blue" @click="saveCabinetGroup">保存</button></div>
</div>
</div>
</div>

<script>
var menuGroupsData=[
{key:'workbench',title:'工作台',defaultOpen:true,items:[{key:'dashboard',label:'主控台'}]},
{key:'dev-mgr',title:'设备管理',defaultOpen:true,items:[{key:'machine-list',label:'机器列表'},{key:'device-logs',label:'设备日志'},{key:'door-records',label:'开门记录'},{key:'pending-cmds',label:'待执行命令'}]},
{key:'loc-mgr',title:'网点管理',defaultOpen:true,items:[{key:'location-list',label:'网点列表'}]},
{key:'order-mgr',title:'订单管理',defaultOpen:true,items:[{key:'online-order',label:'在线订单'},{key:'offline-orders',label:'离线订单'},{key:'remote-open-logs',label:'远程开门日志'}]},
{key:'member-mgr',title:'会员管理',defaultOpen:false,items:[{key:'member-list',label:'会员管理'},{key:'member-withdraw',label:'会员提现'},{key:'member-recharge',label:'会员充值记录'}]},
{key:'complaint-mgr',title:'投诉管理',defaultOpen:false,items:[{key:'complaint-self',label:'自有投诉'},{key:'complaint-wx',label:'微信投诉'}]},
{key:'agent-mgr',title:'代理商管理',defaultOpen:false,items:[{key:'agent-list',label:'代理商列表'}]},
{key:'merchant-mgr',title:'商家管理',defaultOpen:false,items:[{key:'merchant-list',label:'商家列表'},{key:'employee-list',label:'员工管理'}]},
{key:'finance-mgr',title:'财务管理',defaultOpen:false,items:[{key:'settlement',label:'结算流水'},{key:'withdraw-manage',label:'提现管理'},{key:'platform-flow',label:'平台流水'},{key:'fund-flow',label:'资金流水'}]},
{key:'stat-mgr',title:'统计分析',defaultOpen:false,items:[{key:'biz-stat',label:'业务统计'}]},
{key:'company-mgr',title:'公司管理',defaultOpen:false,items:[{key:'company-list',label:'公司管理'}]},
{key:'personal-mgr',title:'个人中心',defaultOpen:false,items:[{key:'personal-info',label:'个人信息'},{key:'change-pwd',label:'修改密码'}]},
{key:'after-mgr',title:'售后管理',defaultOpen:false,items:[{key:'store-record',label:'寄存记录'},{key:'blacklist',label:'黑名单'},{key:'alarm-record',label:'告警记录'},{key:'location-alarm',label:'网点告警'}]},
{key:'apk-mgr',title:'远程升级',defaultOpen:true,items:[{key:'apk-version',label:'APK版本管理'}]},
{key:'sys-mgr',title:'系统管理',defaultOpen:false,items:[{key:'system-settings',label:'系统设置'},{key:'payment-channels',label:'支付渠道'},{key:'user-manage',label:'用户管理'},{key:'role-manage',label:'角色权限'},{key:'data-reset',label:'数据重置'}]}
];

Vue.config.errorHandler=function(err,vm,info){console.error("[Vue Error]",info,err);};var app=new Vue({
el:'#app',
data:{
showLogin:true,loginForm:{username:'',password:'',captcha:''},loginLoading:false,loginError:'',captchaCode:'',
isShrink:false,isMobile:window.innerWidth<=768,sidebarOpen:false,activeMenu:'dashboard',adminUser:'管理员',openGroups:{},menuGroupsData:[],
stats:{},dailyTrend:[],
// Machines
machines:[],machineTotal:0,machinePage:1,machineSearch:{keyword:'',status:''},machineMoreOpen:null,
cabinetModal:false,cabinetForm:{},cabinetFormTitle:'',cabinetEditTab:'basic',deviceDetailModal:false,deviceDetail:null,doorStatusLoading:false,doorStatusResult:null,addSlotModal:false,addSlotForm:{slot_size:'medium',board_no:1,slot_count:1},selectedSlotIds:[],slotBatchMode:false,deviceQrcodeModal:false,deviceQrcode:null,
mainboardModal:false,mainboardForm:{},mainboardsList:[],
slotModal:false,slotGridData:[],slotEditModal:false,slotEditForm:{},
// Locations
locations:[],locationTotal:0,locationPage:1,locationSearch:{keyword:''},
locationModal:false,locationQrcodeModal:false,locationQrcode:null,locationForm:{withdraw_mode:'manual_approve',},locationFormTitle:'',locationEditTab:'basic',
// Orders
orders:[],orderTotal:0,orderPage:1,
orderSearch:{province:'',city:'',merchant_id:'',location_id:'',device_id:'',order_id:'',phone:'',wechat_name:'',status:'',logic_mark:'',refund_mark:'',start_date:'2026-05-21',end_date:'2026-06-20'},
orderDetailModal:false,orderDetail:null,
// Members
members:[],memberTotal:0,memberPage:1,selectedMembers:[],memberSearchPhone:'',
memberDetailModal:false,memberDetail:null,
// Withdrawals
withdrawals:[],withdrawalTotal:0,withdrawalPage:1,withdrawalStatusFilter:'',
rejectModal:false,rejectForm:{},
// Complaints
complaints:[],complaintTotal:0,complaintPage:1,complaintStatusFilter:'',
complaintReplyModal:false,complaintReplyForm:{},complaintType:'complaint',
// Agents
agents:[],agentTotal:0,agentPage:1,agentSearch:{keyword:''},
agentModal:false,agentForm:{},agentFormTitle:'',
// Merchants
merchants:[],merchantTotal:0,merchantPage:1,merchantSearch:{keyword:'',agent_id:''},
merchantModal:false,merchantForm:{},merchantFormTitle:'',
// Employees
employees:[],employeeTotal:0,employeePage:1,employeeSearch:{keyword:'',merchant_id:''},
employeeModal:false,employeeForm:{},employeeFormTitle:'',
// Users
users:[],userModal:false,userForm:{},userFormTitle:'',
// APK
apkModal:false,apkForm:{version_name:'',version_code:'',download_url:'http://locker.cqdyxl.com/static/smart-locker.apk',update_desc:''},currentApk:{},
// Password
pwdForm:{old:'',new1:'',new2:''},profileInfo:{},
// After-sales
afterSales:[],afterSalesTotal:0,afterSalesPage:1,afterSalesStatusFilter:'',
afterSalesModal:false,afterSalesForm:{},afterSalesFormTitle:'',
afterSalesHandleModal:false,afterSalesHandleForm:{},
// Stats
statsFilter:{province:'',agent_id:'',location_id:'',start_date:'2026-05-21',end_date:'2026-06-20'},orderStats:{},locationStats:[],statsChart:null,provinces:[],
settleList:[],settleTotal:0,settlePage:1,settleStats:{},settleFilter:{location_id:'',date_start:'',date_end:''},
withdrawList:[],withdrawTotal:0,withdrawPage:1,withdrawFilter:{status:''},
flowList:[],flowTotal:0,flowPage:1,flowFilter:{type:''},flowStats:{},
fundList:[],fundStats:{},
queryType:'order',queryKeyword:'',queryResults:[],
companyList:[],companyModal:false,companyForm:{},
blackList:[],blackModal:false,blackForm:{},
alarmList:[],alarmTotal:0,alarmPage:1,alarmFilter:{status:''},
locAlarmList:[],
roleList:[],roleModal:false,roleForm:{},
resetStats:{},resetSelected:[],
// Payment channels
channels:[],channelModal:false,channelForm:{},channelFormTitle:'',
// Settings
settingsActiveTab:'basic',settings:{system_name:'智能寄存柜'},smsEnabled:false,
// Toast/Confirm
toastMsg:'',toastType:'success',toastTimer:null,confirmVisible:false,confirmMsg:'',confirmCb:null,
// P1 Data
settingsData:{},settingsLoading:false,orderVisibility:{order_hide_rate:0,order_hide_whitelist:''},dupFilter:{duplicate_filter_enabled:0,duplicate_days:7,duplicate_limit:5},cabinetGroups:[],cabinetGroupsTotal:0,cabinetGroupsPage:1,cabinetGroupForm:{},cabinetGroupModal:false,offlineOrders:[],offlineOrdersTotal:0,offlineOrdersPage:1,
// P2 Data
remoteOpenLogs:[],remoteOpenLogsTotal:0,remoteOpenLogsPage:1,deviceLogList:[],deviceLogTotal:0,deviceLogPage:1,doorRecords:[],doorRecordsTotal:0,doorRecordsPage:1,pendingCmds:[],pendingCmdsTotal:0,pendingCmdsPage:1
},
computed:{
currentTitle:function(){for(var g of menuGroupsData)for(var it of g.items)if(it.key===this.activeMenu)return it.label;return '管理后台';},
isMobileLayout:function(){return this.isMobile}
},
methods:{
api:function(path,data,method){
var m=method||(data?'POST':'GET');
var url='/api'+path;
if(m==='GET'&&data){var p=[];Object.keys(data).forEach(function(k){if(data[k]!==undefined&&data[k]!==null)p.push(k+'='+encodeURIComponent(data[k]));});if(p.length)url+='?'+p.join('&');data=null;}
var opts={method:m,headers:{'Content-Type':'application/json','Authorization':'Bearer '+localStorage.getItem('admin_token')}};
if(data)opts.body=JSON.stringify(data);
return fetch(url,opts).then(function(r){
if(r.status===401){app.showLogin=true;localStorage.removeItem('admin_token');throw new Error('未登录');}
return r.json();
}).then(function(d){
if(d.code&&d.code!==0&&d.code!==200)throw new Error(d.message||'请求失败');
return d;
});
},
toast:function(msg,type){this.toastMsg=msg;this.toastType=type||'success';var self=this;clearTimeout(this.toastTimer);this.toastTimer=setTimeout(function(){self.toastMsg='';},2500);},
confirm2:function(msg,cb){this.confirmMsg=msg;this.confirmCb=cb;this.confirmVisible=true;},
statusText:function(s){return {1:'待支付',2:'使用中',3:'退款异常',4:'已结算',5:'退款失败',6:'已关闭'}[s]||'未知';},
statusClass:function(s){return {1:'orange',2:'blue',3:'orange',4:'green',5:'red',6:'gray'}[s]||'gray';},
switchPage:function(key){this.activeMenu=key;},
genCaptcha:function(){var chars='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';var code='';for(var i=0;i<4;i++)code+=chars[Math.floor(Math.random()*chars.length)];this.captchaCode=code;return code;},
drawCaptcha:function(){var canvas=document.getElementById('captchaCanvas');if(!canvas)return;var ctx=canvas.getContext('2d');var code=this.genCaptcha();ctx.fillStyle='#f0f0f0';ctx.fillRect(0,0,120,40);for(var i=0;i<4;i++){ctx.fillStyle='#'+Math.floor(Math.random()*0x666666+0x333333).toString(16);ctx.font=(16+Math.random()*8)+'px Arial';ctx.fillText(code[i],10+i*26,26+Math.random()*6);}for(var i=0;i<3;i++){ctx.strokeStyle='#999';ctx.beginPath();ctx.moveTo(Math.random()*120,Math.random()*40);ctx.lineTo(Math.random()*120,Math.random()*40);ctx.stroke();}},
doLogin:function(){
var self=this;
if(!this.loginForm.username||!this.loginForm.password){this.loginError='请输入用户名和密码';return;}
if(!this.loginForm.captcha){this.loginError='请输入验证码';return;}
if(this.loginForm.captcha.toUpperCase()!==this.captchaCode){this.loginError='验证码错误';this.drawCaptcha();return;}
this.loginLoading=true;this.loginError='';
fetch('/api/admin/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(this.loginForm)}).then(function(r){return r.json();}).then(function(d){
self.loginLoading=false;
if(d.code===0||d.code===200){localStorage.setItem('admin_token',d.data&&d.data.token||'');self.adminUser=d.data&&d.data.username||'管理员';self.showLogin=false;self.loadDashboard();}
else{self.loginError=d.message||'登录失败';self.drawCaptcha();}
}).catch(function(e){self.loginLoading=false;self.loginError='网络错误';self.drawCaptcha();});
},
doLogout:function(){localStorage.removeItem('admin_token');this.showLogin=true;this.activeMenu='dashboard';},
// Dashboard
loadDashboard:function(){var self=this;this.api('/admin/dashboard').then(function(d){self.stats=d.data||{};}).catch(function(){});self.loadDailyTrend();},
loadDailyTrend:function(){var self=this;this.api('/admin/daily-trend').then(function(d){self.dailyTrend=d.data||[];self.$nextTick(function(){self.renderTrendChart();});}).catch(function(){});},
renderTrendChart:function(){var el=document.getElementById('dailyChart');if(!el||typeof echarts==='undefined')return;var chart=echarts.init(el);var dates=[],counts=[],amounts=[];(this.dailyTrend||[]).forEach(function(d){dates.push(d.date);counts.push(d.count);amounts.push(parseFloat(d.amount||0));});chart.setOption({tooltip:{trigger:'axis'},legend:{data:['订单数','金额']},xAxis:{type:'category',data:dates},yAxis:[{type:'value',name:'订单数'},{type:'value',name:'金额(元)'}],series:[{name:'订单数',type:'bar',data:counts,itemStyle:{color:'#667eea'}},{name:'金额',type:'line',yAxisIndex:1,data:amounts,itemStyle:{color:'#e6a23c'}}]});window.addEventListener('resize',function(){chart.resize();});},
// Machines
loadMachines:function(p){var self=this;if(p)this.machinePage=p;this.api('/admin/devices',{keyword:this.machineSearch.keyword,status:this.machineSearch.status,page:this.machinePage}).then(function(d){self.machines=d.data&&d.data.list||[];self.machineTotal=d.data&&d.data.total||0;}).catch(function(){});},
showCabinetModal:function(row){this.cabinetForm=row?JSON.parse(JSON.stringify(row)):{cabinet_code:'',name:'',total_slots:12,status:1,location_id:'',mainboard_device_id:'',mainboard_source:'WT',deposit_amount:20,charge_mode:'deposit',per_use_price:0,usage_rules:'存放时间截至到当日23:00，请提前取走物品\n避免无效占用，请支付保证金20元\n寄存结束后押金即可退回，请务必关好柜门',business_status:'open',device_type:'screen',customer_phone:'',iot_company:'',iot_iccid:'',clean_balance_enabled:false,clean_balance_time:'',clean_balance_period:1,deposit_timeout:24};this.cabinetFormTitle=row?'编辑设备':'新增设备';this.cabinetEditTab='basic';this.cabinetModal=true;},
saveCabinet:function(){var self=this;this.api('/admin/cabinet/save',this.cabinetForm).then(function(d){self.toast('保存成功');self.cabinetModal=false;self.loadMachines();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
deleteCabinet:function(row){var self=this;this.confirm2('确定删除设备 '+row.cabinet_code+'?',function(){self.api('/admin/cabinet/delete',{id:row.id}).then(function(){self.toast('删除成功');self.loadMachines();}).catch(function(e){self.toast(e.message||'删除失败','error');});});},
toggleCabinetStatus:function(row){var self=this;var newSt=row.status===1?0:1;this.api('/admin/cabinet/save',Object.assign({},row,{status:newSt})).then(function(){self.toast('操作成功');self.loadMachines();}).catch(function(e){self.toast(e.message||'操作失败','error');});},
forceUpdateDevice:function(row){var self=this;if(!row.is_online){this.toast('设备离线，无法更新','warning');return;}this.confirm2('确定推送更新到 '+row.cabinet_code+'?',function(){self.api('/admin/force-update',{device_id:row.mainboard_device_id}).then(function(){self.toast('已推送更新');}).catch(function(e){self.toast(e.message||'推送失败','error');});});},
resetActivation:function(row){var self=this;this.confirm2('确定重置 '+row.cabinet_code+' 的激活状态?',function(){self.api('/admin/reset-activation',{cabinet_id:row.id}).then(function(){self.toast('已重置激活');self.loadMachines();}).catch(function(e){self.toast(e.message||'重置失败','error');});});},
// Mainboard
showMainboardModal:function(row){this.cabinetForm=JSON.parse(JSON.stringify(row));this.loadMainboards(row.id);this.mainboardModal=true;},
loadMainboards:function(cabinetId){var self=this;this.api('/admin/mainboards',{cabinet_id:cabinetId}).then(function(d){self.mainboardsList=Array.isArray(d.data)?d.data:(d.data&&d.data.list||[]);}).catch(function(){self.mainboardsList=[];});},
addMainboard:function(){this.mainboardForm={board_index:1,board_type:'main',serial_port:'ttyS4',baud_rate:9600,protocol:'YBM',address:'01',slot_count:24,cabinet_id:this.cabinetForm.id};this.mainboardModal=true;},
saveMainboard:function(){var self=this;this.api('/admin/mainboards/save',this.mainboardForm).then(function(){self.toast('保存成功');self.mainboardModal=false;self.loadMainboards(self.cabinetForm.id);}).catch(function(e){self.toast(e.message||'保存失败','error');});},
editMainboard:function(row){this.mainboardForm={id:row.id,board_index:row.board_index,board_type:'main',serial_port:row.serial_port,baud_rate:row.baud_rate,protocol:row.protocol||'YBM',address:row.address||'01',slot_count:row.slot_count,cabinet_id:this.cabinetForm.id};},
deleteMainboard:function(row){var self=this;this.confirm2('确定删除此主板?',function(){self.api('/admin/mainboards/delete',{id:row.id}).then(function(){self.loadMainboards(self.cabinetForm.id);}).catch(function(e){self.toast(e.message||'删除失败','error');});});},
generateSlots:function(){var self=this;this.confirm2('将根据主板配置重新生成柜格，已有柜格数据会被清除，确定?',function(){self.api('/admin/mainboards/generate-slots',{cabinet_id:self.cabinetForm.id}).then(function(d){self.toast(d.message||'生成成功');}).catch(function(e){self.toast(e.message||'生成失败','error');});});},
// Slots
showSlotModal:function(row){console.log("showSlotModal",row);this.cabinetForm=JSON.parse(JSON.stringify(row));this.loadSlots(row.id);this.slotModal=true;console.log("slotModal set to",this.slotModal);},batchDeleteSelected:function(){var self=this;if(!this.selectedSlotIds.length){return this.toast("请先选择柜门","error");}if(!confirm("确定删除选中的"+this.selectedSlotIds.length+"个柜门？"))return;this.api("/admin/slots/batch-delete",{ids:this.selectedSlotIds}).then(function(d){self.toast(d.message||"删除成功");self.selectedSlotIds=[];self.loadSlots(self.cabinetForm.id);}).catch(function(e){self.toast(e.message||"删除失败","error");});},batchOpenSlots2:function(){var self=this;var ids=this.selectedSlotIds;if(!ids.length){return this.toast("请先选择柜门","error");}ids.forEach(function(sid){self.api("/admin/slot/open",{slot_id:sid}).catch(function(){});});this.toast("批量开门指令已发送");},clearAllSlots2:function(){var self=this;if(!confirm("确认清柜？将结束所有活跃订单并开门"))return;var cid=this.cabinetForm.id;this.api("/admin/device/clear-all",{cabinet_id:cid}).then(function(d){self.toast(d.message||"清柜成功");self.loadSlots(cid);}).catch(function(e){self.toast(e.message||"清柜失败","error");});},batchSetSlotStatus:function(){var self=this;var ids=this.selectedSlotIds;if(!ids.length){return this.toast("请先选择柜门","error");}var st=prompt("设置状态：1=空闲 2=占用 3=维护");if(!st)return;ids.forEach(function(sid){self.api("/admin/slot/update-status",{slot_id:sid,status:parseInt(st)}).catch(function(){});});this.toast("状态已更新");setTimeout(function(){self.loadSlots(self.cabinetForm.id);},500);},toggleSelectAllSlots:function(){var all=this.slots.map(function(s){return s.id});if(this.selectedSlotIds.length===all.length){this.selectedSlotIds=[];}else{this.selectedSlotIds=all;}},showAddSlotModal:function(){this.addSlotForm={slot_size:'medium',board_no:1,slot_count:1};this.addSlotModal=true;},saveAddSlot:function(){var self=this;this.api('/admin/slot/add',{cabinet_id:this.cabinetForm.id,slot_size:this.addSlotForm.slot_size||'medium',board_no:this.addSlotForm.board_no||1,slot_count:this.addSlotForm.slot_count||1}).then(function(d){self.toast(d.message||'添加成功');self.addSlotModal=false;self.loadSlots(self.cabinetForm.id);}).catch(function(e){self.toast(e.message||'添加失败','error');});},
loadSlots:function(cabinetId){var self=this;this.api('/admin/slots',{cabinet_id:cabinetId}).then(function(d){self.slotGridData=d.data&&d.data.list||[];}).catch(function(){self.slotGridData=[];});},
showSlotEdit:function(slot){this.slotEditForm=JSON.parse(JSON.stringify(slot));this.slotEditModal=true;},
saveSlotEdit:function(){var self=this;this.api('/admin/slot/save',this.slotEditForm).then(function(){self.toast('保存成功');self.slotEditModal=false;self.loadSlots(self.slotModal?self.cabinetForm.id:self.deviceDetail&&self.deviceDetail.id);}).catch(function(e){self.toast(e.message||'保存失败','error');});},deleteSlot:function(){var self=this;if(!this.slotEditForm||!this.slotEditForm.id)return;this.confirm2('确定删除柜门 '+this.slotEditForm.slot_number+'?',function(){self.api('/admin/slot/delete',{id:self.slotEditForm.id}).then(function(){self.toast('删除成功');self.slotEditModal=false;self.loadSlots(self.slotModal?self.cabinetForm.id:self.deviceDetail&&self.deviceDetail.id);}).catch(function(e){self.toast(e.message||'删除失败','error');});});},
openAllSlots:function(){var self=this;this.confirm2('确定开启所有正常柜门?',function(){self.api('/admin/slots/open-all',{cabinet_id:self.cabinetForm.id}).then(function(){self.toast('已发送开门指令');}).catch(function(e){self.toast(e.message||'操作失败','error');});});},
// Locations
loadLocations:function(p){var self=this;if(p)this.locationPage=p;this.api('/admin/locations',{keyword:this.locationSearch.keyword,page:this.locationPage}).then(function(d){self.locations=d.data&&d.data.list||[];self.locationTotal=d.data&&d.data.total||0;}).catch(function(){});},
showLocationModal:function(row){this.locationForm=row?JSON.parse(JSON.stringify(row)):{};if(!this.locationForm.id){Object.assign(this.locationForm,{name:'',address:'',merchant_id:'',status:1,withdraw_enabled:true,show_refunding_status:true,auto_approve_day:7,auto_approve_time:'12:00',auto_approve_rate:80,click_free_count:0,anti_test_minutes:0,anti_test_auto_refund:false,hide_ratio:0,whitelist_phones:'',duplicate_filter_enabled:false,duplicate_filter_days:30,duplicate_filter_limit:5,allow_slot_select:false,slot_assign_mode:'auto',allow_mid_retrieve:true,retrieve_mode:'both',allow_h5_to_mp:false,show_qr_follow:false,force_follow_mp:false,h5_url:'',show_slot_count:true,screen_show_title:true,screen_title:'',slot_full_alert:false,slot_full_text:'',end_alert_minutes:0,enable_clear_box:false,clear_box_time:'23:00',clear_box_cycle:1,deposit_random:false,deposit_min:0,deposit_max:0,contact_phone:''});}this.locationFormTitle=row?'编辑网点':'新增网点';this.locationEditTab='basic';this.locationModal=true;},
saveLocation:function(){var self=this;this.api('/admin/location/save',this.locationForm).then(function(){self.toast('保存成功');self.locationModal=false;self.loadLocations();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
deleteLocation:function(row){var self=this;this.confirm2('确定删除网点 '+row.name+'?',function(){self.api('/admin/location/delete',{id:row.id}).then(function(){self.toast('删除成功');self.loadLocations();}).catch(function(e){self.toast(e.message||'删除失败','error');});});},
// Orders
loadOrders:function(p){var self=this;if(p)this.orderPage=p;var params={page:this.orderPage,limit:10};Object.keys(this.orderSearch).forEach(function(k){if(self.orderSearch[k]!==''&&self.orderSearch[k]!==null)params[k]=self.orderSearch[k];});this.api('/admin/orders',params).then(function(d){self.orders=d.data&&d.data.list||[];self.orderTotal=d.data&&d.data.total||0;}).catch(function(){});},
resetOrderSearch:function(){this.orderSearch={province:'',city:'',merchant_id:'',location_id:'',device_id:'',order_id:'',phone:'',wechat_name:'',status:'',logic_mark:'',refund_mark:'',start_date:'2026-05-21',end_date:'2026-06-20'};this.loadOrders();},
viewOrderDetail:function(row){var self=this;this.api('/admin/order/detail',{order_id:row.id}).then(function(d){self.orderDetail=d.data||row;self.orderDetailModal=true;}).catch(function(){self.orderDetail=row;self.orderDetailModal=true;});},orderOpenDoor:function(){var self=this;if(!this.orderDetail||!this.orderDetail.id){return alert('订单信息异常');}if(!confirm('确认要为该订单开门吗？'))return;this.api('/admin/order/open-door',{order_id:this.orderDetail.id}).then(function(d){alert(d.message||'开门指令已发送');}).catch(function(e){alert('开门失败：'+(e.message||'未知错误'));});},
refundOrder:function(row){var self=this;this.confirm2('确定退款订单 '+row.order_no+'?',function(){self.api('/admin/order/refund',{order_id:row.id}).then(function(){self.toast('退款成功');self.loadOrders();}).catch(function(e){self.toast(e.message||'退款失败','error');});});},
closeOrder:function(row){var self=this;this.confirm2('确定结束订单 '+row.order_no+'?',function(){self.api('/admin/order/close',{order_id:row.id}).then(function(){self.toast('已结束');self.loadOrders();}).catch(function(e){self.toast(e.message||'操作失败','error');});});},
openOrderLock:function(row){var self=this;this.confirm2('确定远程开柜 '+row.order_no+'?',function(){self.api('/admin/order/open-lock',{order_id:row.id}).then(function(){self.toast('开柜指令已发送');}).catch(function(e){self.toast(e.message||'操作失败','error');});});},
isRecent3Days:function(dt){if(!dt)return false;var d=new Date(dt.replace(/-/g,'/'));if(isNaN(d))return false;var now=new Date();var diff=now-d;return diff<=3*24*60*60*1000;},
toggleLogicMark:function(row){var self=this;var newMark=row.logic_mark==='Y'?'N':'Y';this.api('/admin/order/toggle-logic',{order_id:row.id,logic_mark:newMark}).then(function(){self.toast('已切换');self.loadOrders();}).catch(function(e){self.toast(e.message||'操作失败','error');});},
exportOrders:function(){var params=[];Object.keys(this.orderSearch).forEach(function(k){if(app.orderSearch[k]!==''&&app.orderSearch[k]!==null)params.push(k+'='+encodeURIComponent(app.orderSearch[k]));});window.open('/api/admin/orders/export?'+params.join('&')+'&token='+localStorage.getItem('admin_token'));},
// Members
loadMembers:function(p){var self=this;if(p)this.memberPage=p;this.api('/admin/members',{phone:this.memberSearchPhone,page:this.memberPage}).then(function(d){self.members=d.data&&d.data.list||[];self.memberTotal=d.data&&d.data.total||0;}).catch(function(){});},
toggleSelectAllMembers:function(){if(this.selectedMembers.length===this.members.length){this.selectedMembers=[];}else{this.selectedMembers=this.members.map(function(m){return m.phone;});}},refundMember:function(m){var self=this;this.confirm2('确定退款 ¥'+(m.balance||0)+' 到 '+m.phone+'?',function(){self.api('/admin/member/refund',{phone:m.phone,amount:m.balance}).then(function(d){self.toast(d.message||'退款成功');self.loadMembers();}).catch(function(e){self.toast(e.message||'退款失败','error');});});},batchRefundMembers:function(){var self=this;if(!this.selectedMembers.length){this.toast('请先选择会员','warning');return;}var phones=this.selectedMembers;this.confirm2('确定批量退款 '+phones.length+' 个会员?',function(){self.api('/admin/member/batch-refund',{phones:phones}).then(function(d){self.toast(d.message||'批量退款成功');self.selectedMembers=[];self.loadMembers();}).catch(function(e){self.toast(e.message||'批量退款失败','error');});});},viewMemberDetail:function(row){var self=this;this.api('/admin/member/detail',{user_id:row.id}).then(function(d){self.memberDetail=d.data||row;self.memberDetailModal=true;}).catch(function(){self.memberDetail=row;self.memberDetailModal=true;});},
// Withdrawals
loadWithdrawals:function(p){var self=this;if(p)this.withdrawalPage=p;this.api('/admin/withdrawals',{status:this.withdrawalStatusFilter,page:this.withdrawalPage}).then(function(d){self.withdrawals=d.data&&d.data.list||[];self.withdrawalTotal=d.data&&d.data.total||0;}).catch(function(){});},
approveWithdrawal:function(row){var self=this;this.confirm2('确定通过此提现申请?',function(){self.api('/admin/withdrawal/approve',{id:row.id}).then(function(){self.toast('已通过');self.loadWithdrawals();}).catch(function(e){self.toast(e.message||'操作失败','error');});});},confirmRefund:function(row){var self=this;this.confirm2('确认退款已完成?',function(){self.api('/admin/withdrawal/confirm-refund',{id:row.id}).then(function(){self.toast('已确认退款');self.loadWithdrawals();}).catch(function(e){self.toast(e.message||'操作失败','error');});});},
showRejectModal:function(row){this.rejectForm={id:row.id,amount:row.amount,reason:''};this.rejectModal=true;},
submitReject:function(){var self=this;this.api('/admin/withdrawal/reject',this.rejectForm).then(function(){self.toast('已拒绝');self.rejectModal=false;self.loadWithdrawals();}).catch(function(e){self.toast(e.message||'操作失败','error');});},
// Complaints
loadComplaints:function(p){var self=this;if(p)this.complaintPage=p;this.api('/admin/complaints',{type:this.complaintType,status:this.complaintStatusFilter,page:this.complaintPage}).then(function(d){self.complaints=d.data&&d.data.list||[];self.complaintTotal=d.data&&d.data.total||0;}).catch(function(){});},
showComplaintReply:function(row){this.complaintReplyForm={id:row.id,content:row.content,reply:''};this.complaintReplyModal=true;},
