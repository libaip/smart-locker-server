saveMerchant:function(){var self=this;this.api('/admin/merchant/save',this.merchantForm).then(function(){self.toast('保存成功');self.merchantModal=false;self.loadMerchants();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
deleteMerchant:function(row){var self=this;this.confirm2('确定删除商家 '+row.name+'?',function(){self.api('/admin/merchant/delete',{id:row.id}).then(function(){self.toast('删除成功');self.loadMerchants();}).catch(function(e){self.toast(e.message||'删除失败','error');});});},
toggleMerchantStatus:function(row){var self=this;var newSt=row.status===1?0:1;this.api('/admin/merchant/save',Object.assign({},row,{status:newSt})).then(function(){self.toast('操作成功');self.loadMerchants();}).catch(function(e){self.toast(e.message||'操作失败','error');});},
// Employees
loadEmployees:function(p){var self=this;if(p)this.employeePage=p;this.api('/admin/employees',{keyword:this.employeeSearch.keyword,merchant_id:this.employeeSearch.merchant_id,page:this.employeePage}).then(function(d){self.employees=d.data&&d.data.list||[];self.employeeTotal=d.data&&d.data.total||0;}).catch(function(){});},
showEmployeeModal:function(row){this.employeeForm=row?JSON.parse(JSON.stringify(row)):{name:'',phone:'',password:'',merchant_id:'',role:'staff',status:1};this.employeeFormTitle=row?'编辑员工':'新增员工';this.employeeModal=true;},
saveEmployee:function(){var self=this;this.api('/admin/employee/save',this.employeeForm).then(function(){self.toast('保存成功');self.employeeModal=false;self.loadEmployees();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
toggleEmployeeStatus:function(row){var self=this;var newSt=row.status===1?0:1;this.api('/admin/employee/save',Object.assign({},row,{status:newSt})).then(function(){self.toast('操作成功');self.loadEmployees();}).catch(function(e){self.toast(e.message||'操作失败','error');});},
