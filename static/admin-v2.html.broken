Vue.component('page-online-order',{template:'\
<div>\
<div class="page-box">\
<div class="box-header"><h3>在线订单</h3><div><button class="btn btn-sm btn-green" @click="$parent.exportOrders()">导出</button></div></div>\
<div class="search-bar">\
<div class="search-item"><label>订单ID</label><input v-model="$parent.orderSearch.order_id" placeholder="订单ID"></div>\
<div class="search-item"><label>手机号</label><input v-model="$parent.orderSearch.phone" placeholder="用户手机"></div><div class="search-item"><label>微信名</label><input v-model="$parent.orderSearch.wechat_name" placeholder="微信昵称"></div>\
<div class="search-item"><label>状态</label><select v-model="$parent.orderSearch.status"><option value="">全部</option><option value="1">待支付</option><option value="2">使用中</option><option value="3">已取物</option><option value="4">已结算</option><option value="5">已取消</option></select></div>\
<div class="search-item"><label>逻辑标记</label><select v-model="$parent.orderSearch.logic_mark"><option value="">全部</option><option value="Y">Y(隐藏)</option><option value="N">N(正常)</option></select></div>\
<div class="search-item"><label>开始日期</label><input type="date" v-model="$parent.orderSearch.start_date"></div>\<div class="search-item"><label>结束日期</label><input type="date" v-model="$parent.orderSearch.end_date"></div>\<div class="search-item"><label>退款标记</label><select v-model="$parent.orderSearch.refund_mark"><option value="">全部</option><option value="auto_approve">自动审批</option><option value="user_withdraw">用户提现</option><option value="manual">人工审批</option><option value="none">未退款</option></select></div>\
<div class="search-item"><label>网点</label><select v-model="$parent.orderSearch.location_id"><option value="">全部</option><option v-for="l in $parent.locations" :value="l.id">{{l.name}}</option></select></div>\
<div class="search-item"><label>设备</label><select v-model="$parent.orderSearch.device_id"><option value="">全部</option><option v-for="d in $parent.machines" :value="d.id">{{d.cabinet_code||d.name}}</option></select></div>\
<div class="search-item"><label>&nbsp;</label><div><button class="btn btn-sm btn-blue" @click="$parent.loadOrders(1)">查询</button> <button class="btn btn-sm" @click="$parent.resetOrderSearch()">重置</button></div></div>\
</div>\
<div class="table-scroll"><table><tr><th>订单号</th><th>商家</th><th>网点</th><th>设备</th><th>柜格</th><th>用户手机</th><th>密码</th><th>金额</th><th>退款</th><th>开始时间</th><th>结束时间</th><th>逻辑</th><th>退款标记</th><th>状态</th><th class="action-col">操作</th></tr>\
<tr v-for="o in $parent.orders"><td>{{o.order_no}}</td><td>{{o.merchant_name||\'-\'}}</td><td>{{o.location_name||\'-\'}}</td><td>{{o.cabinet_code}}</td><td>{{o.compartment_number}}</td><td>{{o.user_phone}}</td><td>{{o.password}}</td><td>¥{{o.deposit_amount||0}}</td><td>¥{{o.refund_amount||0}}</td><td>{{o.store_time}}</td><td>{{o.retrieve_time||\'-\'}}</td><td><span v-if="o.logic_mark===\'Y\'" class="status-tag red">隐藏</span><span v-else-if="o.logic_mark===\'N\'" class="status-tag green">正常</span><span v-else>-</span></td><td><span v-if="o.refund_mark===\'auto_approve\'" class="status-tag orange">自动</span><span v-else-if="o.refund_mark===\'user_withdraw\'" class="status-tag blue">提现</span><span v-else-if="o.refund_mark===\'manual\'" class="status-tag blue">人工</span><span v-else-if="o.refund_mark===\'none\'" class="status-tag gray">未退</span><span v-else>-</span></td><td><span :class="\'status-tag \'+$parent.statusClass(o.status)">{{$parent.statusText(o.status)}}</span></td><td style="white-space:nowrap" class="action-col">\
<button class="btn-text blue" @click="$parent.viewOrderDetail(o)">详情</button>\
<button v-if="o.status===2" class="btn-text green" @click="$parent.openOrderLock(o)">开柜</button>\
<button v-if="(o.status===2||o.status===3||o.status===4)&&$parent.isRecent3Days(o.store_time)" class="btn-text blue" @click="$parent.openOrderLock(o)">开门</button>\
<button v-if="(o.status===2||o.status===4||o.status===5)&&o.refund_status!==\'refunded\'" class="btn-text orange" @click="$parent.refundOrder(o)">退款</button><button v-if="(o.refund_status===\'refunded\'||o.status===3)" class="btn-text" style="color:#bbb;cursor:default" disabled>已退款</button>\
<button v-if="o.status===1||o.status===2" class="btn-text red" @click="$parent.closeOrder(o)">结束</button>\
<button class="btn-text" @click="$parent.toggleLogicMark(o)">{{o.logic_mark===\'Y\'?\'显示\':\'隐藏\'}}</button>\
</td></tr>\
<tr v-if="!$parent.orders.length"><td colspan="15" class="empty-row">暂无数据</td></tr>\
</table></div>\
<div class="pagination"><span>共 {{$parent.orderTotal}} 条</span><div><button :disabled="$parent.orderPage<=1" @click="$parent.loadOrders($parent.orderPage-1)">上一页</button><span style="margin:0 8px">{{$parent.orderPage}} / {{$parent.pageCount($parent.orderTotal,10)||1}}</span><button :disabled="$parent.orderPage>=$parent.pageCount($parent.orderTotal,10)" @click="$parent.loadOrders($parent.orderPage+1)">下一页</button></div></div>\
</div>\
</div>'});

// Member List
Vue.component('page-member-list',{template:`
<div>
<div class="page-box">
<div class="box-header"><h3>会员管理</h3></div>
<div class="search-bar">
<div class="search-item"><label>手机号</label><input v-model="$parent.memberSearchPhone" placeholder="请输入手机号" @keyup.enter="$parent.loadMembers(1)"></div>
<div class="search-item"><label>&nbsp;</label><div><button class="btn btn-sm btn-blue" @click="$parent.loadMembers(1)">搜索</button></div></div>
</div>
<div style="margin-bottom:10px"><button class="btn btn-sm" style="background:#E57373;color:#000;border:none;border-radius:4px;padding:4px 14px;cursor:pointer" @click="$parent.batchRefundMembers()" :disabled="!$parent.selectedMembers.length">批量退款 ({{$parent.selectedMembers.length}})</button><button class="btn btn-sm" style="background:#4FC3F7;color:#000;border:none;border-radius:4px;padding:4px 14px;cursor:pointer;margin-left:8px" @click="$parent.toggleSelectAllMembers()">{{($parent.members.length&&$parent.selectedMembers.length===$parent.members.length)?'取消全选':'全选'}}</button></div>
<table><tr><th><input type="checkbox" @change="$parent.toggleSelectAllMembers()" :checked="$parent.members.length&&$parent.selectedMembers.length===$parent.members.length"></th><th>手机号</th><th>押金余额</th><th>累计存入</th><th>累计订单</th><th>操作</th></tr>
<tr v-for="m in $parent.members"><td><input type="checkbox" :value="m.phone" v-model="$parent.selectedMembers"></td><td>{{m.phone}}</td><td>¥{{m.balance||0}}</td><td>¥{{m.total_deposit||0}}</td><td>{{m.total_orders||0}}</td><td><button class="btn-sm" style="background:#81C784;color:#000;border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:12px" @click="$parent.viewMemberDetail(m)">详情</button> <button class="btn-sm" style="background:#FFB74D;color:#000;border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:12px" @click="$parent.refundMember(m)" :disabled="!m.balance||m.balance<=0">退款</button></td></tr>
<tr v-if="!$parent.members.length"><td colspan="6" class="empty-row">暂无数据</td></tr>
</table>
<div class="pagination"><span>共 {{$parent.memberTotal}} 条</span><div><button :disabled="$parent.memberPage<=1" @click="$parent.loadMembers($parent.memberPage-1)">上一页</button><span style="margin:0 8px">{{$parent.memberPage}} / {{$parent.pageCount($parent.memberTotal,10)||1}}</span><button :disabled="$parent.memberPage>=$parent.pageCount($parent.memberTotal,10)" @click="$parent.loadMembers($parent.memberPage+1)">下一页</button></div></div>
</div>
</div>`});

// Member Withdraw
Vue.component('page-member-withdraw',{template:'\
<div>\
<div class="page-box">\
<div class="box-header"><h3>会员提现</h3></div>\
<div class="search-bar">\
<div class="search-item"><label>状态</label><select v-model="$parent.withdrawalStatusFilter" @change="$parent.loadWithdrawals(1)"><option value="">全部</option><option value="0">待审核</option><option value="1">退款中</option><option value="2">已退款</option><option value="3">已拒绝</option></select></div>\
</div>\
<table><tr><th>申请时间</th><th>用户手机</th><th>用户姓名</th><th>微信名</th><th>提现金额</th><th>状态</th><th>审批人</th><th>操作</th></tr>\
<tr v-for="w in $parent.withdrawals"><td>{{w.created_at}}</td><td>{{w.user_phone}}</td><td>{{w.user_name||\'-\'}}</td><td>{{w.wechat_name||'-'}}</td><td>¥{{w.amount}}</td><td><span v-if="w.status===0" class="status-tag orange">待审核</span><span v-else-if="w.status===1" class="status-tag blue">退款中</span><span v-else-if="w.status===2" class="status-tag green">已退款</span><span v-else-if="w.status===3" class="status-tag red">已拒绝</span></td><td>{{w.approver||\'-\'}}</td><td><template v-if="w.status===0"><button class="btn-text green" @click="$parent.approveWithdrawal(w)">通过</button><button class="btn-text red" @click="$parent.showRejectModal(w)">拒绝</button></template><template v-else-if="w.status===1"><button class="btn-text green" @click="$parent.confirmRefund(w)">确认已退款</button></template><span v-else style="color:#999">-</span></td></tr>\
<tr v-if="!$parent.withdrawals.length"><td colspan="9" class="empty-row">暂无数据</td></tr>\
</table>\
<div class="pagination"><span>共 {{$parent.withdrawalTotal}} 条</span><div><button :disabled="$parent.withdrawalPage<=1" @click="$parent.loadWithdrawals($parent.withdrawalPage-1)">上一页</button><span style="margin:0 8px">{{$parent.withdrawalPage}} / {{$parent.pageCount($parent.withdrawalTotal,10)||1}}</span><button :disabled="$parent.withdrawalPage>=$parent.pageCount($parent.withdrawalTotal,10)" @click="$parent.loadWithdrawals($parent.withdrawalPage+1)">下一页</button></div></div>\
</div>\
</div>'});

