loadApkVersion:function(){var self=this;this.api('/admin/apk-version').then(function(d){self.currentApk=d.data||{};}).catch(function(){});},
saveApkVersion:function(){var self=this;if(!this.apkForm.version_name||!this.apkForm.version_code){this.toast('请填写版本信息','warning');return;}this.api('/admin/apk-version/save',this.apkForm).then(function(){self.toast('发布成功');self.loadApkVersion();self.apkForm={version_name:'',version_code:'',download_url:'http://locker.cqdyxl.com/static/smart-locker.apk',update_desc:''};}).catch(function(e){self.toast(e.message||'发布失败','error');});},
// Password
changePassword:function(){var self=this;if(!this.pwdForm.old||!this.pwdForm.new1){this.toast('请填写密码','warning');return;}if(this.pwdForm.new1!==this.pwdForm.new2){this.toast('两次密码不一致','error');return;}if(this.pwdForm.new1.length<6){this.toast('新密码至少6位','warning');return;}this.api('/admin/change-password',{old_password:this.pwdForm.old,new_password:this.pwdForm.new1}).then(function(){self.toast('密码修改成功');self.pwdForm={old:'',new1:'',new2:''};}).catch(function(e){self.toast(e.message||'修改失败','error');});},
loadProfile:function(){var self=this;this.api('/roles/list').then(function(d){var list=d.data&&d.data.list||[];var me=list.find(function(r){return r.username===self.adminUser;});if(me){self.profileInfo={id:me.id,role_text:me.role==='admin'?'管理员':me.role==='operator'?'操作员':'查看者',created_at:me.created_at};}else{self.profileInfo={role_text:'未知',created_at:'-'};}}).catch(function(){self.profileInfo={role_text:'-',created_at:'-'};});},
// After-sales
loadAfterSales:function(p){var self=this;if(p)this.afterSalesPage=p;this.api('/admin/after-sales',{status:this.afterSalesStatusFilter,page:this.afterSalesPage}).then(function(d){self.afterSales=d.data&&d.data.list||[];self.afterSalesTotal=d.data&&d.data.total||0;}).catch(function(){});},
showAfterSalesModal:function(row){this.afterSalesForm=row?JSON.parse(JSON.stringify(row)):{cabinet_id:'',type:'',description:''};this.afterSalesFormTitle=row?'编辑工单':'新建工单';this.afterSalesModal=true;},
saveAfterSales:function(){var self=this;this.api('/admin/after-sales/save',this.afterSalesForm).then(function(){self.toast('保存成功');self.afterSalesModal=false;self.loadAfterSales();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
handleAfterSales:function(row){this.afterSalesHandleForm=JSON.parse(JSON.stringify(row));this.afterSalesHandleModal=true;},
saveAfterSalesHandle:function(){var self=this;this.api('/admin/after-sales/handle',this.afterSalesHandleForm).then(function(){self.toast('处理成功');self.afterSalesHandleModal=false;self.loadAfterSales();}).catch(function(e){self.toast(e.message||'处理失败','error');});},
// Stats
loadStats:function(){var self=this;var params={province:this.statsFilter.province,agent_id:this.statsFilter.agent_id,location_id:this.statsFilter.location_id,start_date:this.statsFilter.start_date,end_date:this.statsFilter.end_date};this.api('/admin/biz-stats',params).then(function(d){self.orderStats=d.data||{};self.locationStats=d.data&&d.data.locations||[];self.provinces=d.data&&d.data.provinces||[];self.$nextTick(function(){self.renderStatsChart(d.data&&d.data.daily||[]);});}).catch(function(){});},
resetStatsFilter:function(){this.statsFilter={province:'',agent_id:'',location_id:'',start_date:'2026-05-21',end_date:'2026-06-20'};this.loadStats();},
loadSettlement:function(p){var self=this;if(p)this.settlePage=p;this.api('/settlement/list',{page:this.settlePage,location_id:this.settleFilter.location_id,date_start:this.settleFilter.date_start,date_end:this.settleFilter.date_end}).then(function(d){self.settleList=d.data.list||[];self.settleTotal=d.data.total||0;}).catch(function(){});},
loadSettlementStats:function(){var self=this;this.api('/settlement/stats').then(function(d){self.settleStats=d.data||{};}).catch(function(){});},
loadPlatformFlow:function(p){var self=this;if(p)this.flowPage=p;this.api('/platform-flow/list',{page:this.flowPage,type:this.flowFilter.type}).then(function(d){self.flowList=d.data.list||[];self.flowTotal=d.data.total||0;self.flowStats={total_deposit:d.data.total_deposit,total_refund:d.data.total_refund};}).catch(function(){});},
loadFundFlow:function(){var self=this;this.api('/fund-flow/list').then(function(d){self.fundList=d.data.list||[];self.fundStats={total_users:d.data.total_users,total_balance:d.data.total_balance};}).catch(function(){});},
loadQueryAll:function(){var self=this;if(!this.queryKeyword)return;this.api('/query-all/list',{keyword:this.queryKeyword,type:this.queryType}).then(function(d){self.queryResults=d.data.list||[];}).catch(function(){});},
loadCompanies:function(){var self=this;this.api('/companies/list').then(function(d){self.companyList=d.data.list||[];}).catch(function(){});},
saveCompany:function(){var self=this;this.api('/companies/save',this.companyForm).then(function(){self.toast('保存成功');self.companyModal=false;self.loadCompanies();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
deleteCompany:function(id){var self=this;if(!confirm('确认删除?'))return;this.api('/companies/delete',{id:id}).then(function(){self.toast('删除成功');self.loadCompanies();}).catch(function(e){self.toast(e.message||'删除失败','error');});},
loadBlacklist:function(){var self=this;this.api('/blacklist/list').then(function(d){self.blackList=d.data.list||[];}).catch(function(){});},
saveBlack:function(){var self=this;this.api('/blacklist/save',this.blackForm).then(function(){self.toast('保存成功');self.blackModal=false;self.loadBlacklist();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
deleteBlack:function(id){var self=this;if(!confirm('确认删除?'))return;this.api('/blacklist/delete',{id:id}).then(function(){self.toast('删除成功');self.loadBlacklist();}).catch(function(e){self.toast(e.message||'删除失败','error');});},
loadAlarms:function(p){var self=this;if(p)this.alarmPage=p;this.api('/alarms/list',{page:this.alarmPage,status:this.alarmFilter.status}).then(function(d){self.alarmList=d.data.list||[];self.alarmTotal=d.data.total||0;}).catch(function(){});},
resolveAlarm:function(id){var self=this;this.api('/alarms/resolve',{id:id}).then(function(){self.toast('处理成功');self.loadAlarms();}).catch(function(e){self.toast(e.message||'操作失败','error');});},
loadLocAlarms:function(){var self=this;this.api('/location-alarms/list').then(function(d){self.locAlarmList=d.data.list||[];}).catch(function(){});},
loadRoles:function(){var self=this;this.api('/roles/list').then(function(d){self.roleList=d.data.list||[];}).catch(function(){});},
saveRole:function(){var self=this;this.api('/roles/save',this.roleForm).then(function(){self.toast('保存成功');self.roleModal=false;self.loadRoles();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
loadResetStats:function(){var self=this;this.api('/data-reset/stats').then(function(d){self.resetStats=d.data||{};}).catch(function(){});},

// P1 Methods
loadSettings:function(){var self=this;this.api('/settings').then(function(d){var sd={};if(d&&d.length){d.forEach(function(r){sd[r.setting_key]={value:r.setting_value,desc:r.description||r.setting_key};});}self.settingsData=sd;}).catch(function(e){self.toast(e.message||'加载失败','error');});},
saveSettings:function(){var self=this;var arr=[];for(var k in this.settingsData){arr.push({setting_key:k,setting_value:this.settingsData[k].value});}this.api('/settings/save',{settings:arr}).then(function(){self.toast('保存成功');}).catch(function(e){self.toast(e.message||'保存失败','error');});},
loadOfflineOrders:function(){var self=this;this.api('/admin/offline-orders',{page:this.offlineOrdersPage}).then(function(d){self.offlineOrders=d.data&&d.data.list||[];self.offlineOrdersTotal=d.data&&d.data.total||0;}).catch(function(e){self.toast(e.message||'加载失败','error');});},
showLocationQrcode:function(loc){var self=this;this.api('/admin/location/qrcode',{location_id:loc.id}).then(function(d){self.locationQrcode=d.data;self.locationQrcodeModal=true;}).catch(function(e){self.toast(e.message||'加载失败','error');});},
showDeviceDetail:function(dev){console.log("showDeviceDetail",dev);var self=this;this.api('/admin/device/detail',{id:dev.id}).then(function(d){console.log("detail resp",d);self.deviceDetail=d.data;self.deviceDetailModal=true;app.$nextTick(function(){var m=document.querySelectorAll(".modal-mask");console.log("MODALS IN DOM:",m.length);for(var i=0;i<m.length;i++){console.log(i,m[i].innerHTML.substring(0,80));}});},downloadDeviceQrcode:function(){var self=this;if(!self.deviceQrcode||!self.deviceQrcode.qrcode_img)return;var link=document.createElement('a');link.download='ID'+(self.deviceQrcode.id||'')+'_'+(self.deviceQrcode.cabinet_code||'device')+'_qrcode.png';link.href=self.deviceQrcode.qrcode_img;link.click();},
batchOpenSlots:function(dev){var self=this;var slots=dev.slots||[];var occupied=slots.filter(function(s){return s.status===2;});if(occupied.length===0){self.toast('没有需要开门的柜格','info');return;}self.confirm2('确定打开'+occupied.length+'个占用柜格?',function(){occupied.forEach(function(s){self.api('/admin/device/slot-open',{slot_id:s.id}).then(function(){self.toast('已发送开门指令: '+s.slot_number);}).catch(function(e){self.toast('失败: '+s.slot_number,'error');});});setTimeout(function(){self.showDeviceDetail(dev);},2000);});},clearAllSlots:function(dev){var self=this;self.confirm2('确定清空所有柜格?',function(){var slots=dev.slots||[];slots.forEach(function(s){self.api('/admin/slot/status',{id:s.id,status:1}).then(function(){self.toast('已清空: '+s.slot_number);}).catch(function(e){self.toast('失败: '+s.slot_number,'error');});});setTimeout(function(){self.showDeviceDetail(dev);},2000);});},updateSlotStatus:function(slot){var self=this;var ns=slot.status===1?3:1;self.api('/admin/slot/status',{id:slot.id,status:ns}).then(function(){self.toast('状态已更新');setTimeout(function(){self.showDeviceDetail({id:self.deviceDetail.id});},500);}).catch(function(e){self.toast(e.message||'更新失败','error');});},openSingleSlot:function(slot){var self=this;this.confirm2('确定开柜格 '+slot.slot_number+'?',function(){self.api('/admin/device/slot-open',{slot_id:slot.id}).then(function(){self.toast('开门指令已发送');self.loadSlots(self.slotModal?self.cabinetForm.id:self.deviceDetail&&self.deviceDetail.id);}).catch(function(e){self.toast(e.message||'失败','error');});});},
loadCabinetGroups:function(p){var self=this;if(p)this.cabinetGroupsPage=p;this.api('/admin/cabinet-groups',{page:this.cabinetGroupsPage}).then(function(d){self.cabinetGroups=d.data&&d.data.list||[];self.cabinetGroupsTotal=d.data&&d.data.total||0;}).catch(function(e){self.toast(e.message||'加载失败','error');});},
showCabinetGroupModal:function(row){this.cabinetGroupForm=row?JSON.parse(JSON.stringify(row)):{};this.cabinetGroupModal=true;},
saveCabinetGroup:function(){var self=this;this.api('/admin/cabinet-group/save',this.cabinetGroupForm).then(function(){self.toast('保存成功');self.cabinetGroupModal=false;self.loadCabinetGroups();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
deleteCabinetGroup:function(row){var self=this;this.confirm2('确定删除柜组 '+row.name+'?',function(){self.api('/admin/cabinet-group/delete',{id:row.id}).then(function(){self.toast('删除成功');self.loadCabinetGroups();}).catch(function(e){self.toast(e.message||'删除失败','error');});});},
// P2 Methods
loadRemoteOpenLogs:function(){var self=this;this.api('/admin/remote-open-logs',{page:this.remoteOpenLogsPage}).then(function(d){self.remoteOpenLogs=d.data&&d.data.list||[];self.remoteOpenLogsTotal=d.data&&d.data.total||0;}).catch(function(e){self.toast(e.message||'加载失败','error');});},
loadDeviceLogs:function(){var self=this;this.api('/admin/device-logs',{page:this.deviceLogPage}).then(function(d){self.deviceLogList=d.data&&d.data.list||[];self.deviceLogTotal=d.data&&d.data.total||0;}).catch(function(e){self.toast(e.message||'加载失败','error');});},logTypeText:function(t){var m={heartbeat:'心跳',info:'信息',hb:'心跳',hb_time:'心跳时间',open:'开锁',close:'关锁',error:'错误',warn:'警告',alarm:'报警',online:'在线',offline:'离线',test:'测试'};return m[t]||t||'-';},
        logContentText:function(c){if(!c)return'-';try{var a=JSON.parse(c);if(Array.isArray(a)){var r=a[a.length-1];if(typeof r==='string'&&r.length<50)return r;return a.join(', ');}if(typeof a==='object')return JSON.stringify(a).substring(0,100);return String(a).substring(0,100);}catch(e){return String(c).substring(0,100);}},
        formatTime:function(t){if(!t)return'-';try{var d=new Date(t.replace(' ','T'));if(isNaN(d.getTime()))return t;var mo=d.getMonth()+1,da=d.getDate(),h=d.getHours().toString().padStart(2,'0'),mi=d.getMinutes().toString().padStart(2,'0');return mo+'月'+da+'日 '+h+':'+mi;}catch(e){return t;}},
loadDoorRecords:function(){var self=this;this.api('/admin/door-records',{page:this.doorRecordsPage}).then(function(d){self.doorRecords=d.list||d.data||[];self.doorRecordsTotal=d.total||0;}).catch(function(e){self.toast(e.message||'加载失败','error');});},
loadPendingCmds:function(){var self=this;this.api('/admin/pending-cmds',{page:this.pendingCmdsPage}).then(function(d){self.pendingCmds=d.list||d.data||[];self.pendingCmdsTotal=d.total||0;}).catch(function(e){self.toast(e.message||'加载失败','error');});},
cancelCmd:function(id){var self=this;this.confirm2('确定取消此命令?',function(){self.api('/admin/cancel-cmd',{id:id}).then(function(){self.toast('命令已取消');self.loadPendingCmds();}).catch(function(e){self.toast(e.message||'操作失败','error');});});},

execReset:function(){var self=this;if(!confirm('确认清理选中的'+this.resetSelected.length+'个数据表?此操作不可逆!'))return;this.api('/data-reset/exec',{tables:this.resetSelected}).then(function(){self.toast('清理完成');self.loadResetStats();self.resetSelected=[];}).catch(function(e){self.toast(e.message||'操作失败','error');});},
renderStatsChart:function(trend){var el=document.getElementById('statsChart');if(!el||typeof echarts==='undefined')return;var chart=echarts.init(el);var dates=[],orders=[],deposits=[],refunds=[];trend.forEach(function(d){dates.push(d.date);orders.push(d.order_count||0);deposits.push(parseFloat(d.deposit_total||0));refunds.push(parseFloat(d.refund_total||0));});chart.setOption({tooltip:{trigger:'axis'},legend:{data:['订单数','保证金收入','退款总额']},xAxis:{type:'category',data:dates},yAxis:[{type:'value',name:'订单数'},{type:'value',name:'金额(元)'}],series:[{name:'订单数',type:'bar',data:orders,itemStyle:{color:'#667eea'}},{name:'保证金收入',type:'line',yAxisIndex:1,data:deposits,itemStyle:{color:'#67c23a'}},{name:'退款总额',type:'line',yAxisIndex:1,data:refunds,itemStyle:{color:'#f56c6c'}}]});window.addEventListener('resize',function(){chart.resize();});},
// Channels
loadChannels:function(){var self=this;this.api('/admin/channels').then(function(d){self.channels=d.data||[];}).catch(function(){self.channels=[];});},
showChannelModal:function(row){this.channelForm=row?JSON.parse(JSON.stringify(row)):{name:'',channel_type:'wechat',app_id:'',mch_id:'',api_key:'',status:1};this.channelFormTitle=row?'编辑渠道':'添加渠道';this.channelModal=true;},
saveChannel:function(){var self=this;this.api('/admin/channel/save',this.channelForm).then(function(){self.toast('保存成功');self.channelModal=false;self.loadChannels();}).catch(function(e){self.toast(e.message||'保存失败','error');});},
toggleChannelStatus:function(row){var self=this;var newSt=row.status===1?0:1;this.api('/admin/channel/save',Object.assign({},row,{status:newSt})).then(function(){self.toast('操作成功');self.loadChannels();}).catch(function(e){self.toast(e.message||'操作失败','error');});},
deleteChannel:function(row){var self=this;this.confirm2('确定删除此支付渠道?',function(){self.api('/admin/channel/delete',{id:row.id}).then(function(){self.toast('删除成功');self.loadChannels();}).catch(function(e){self.toast(e.message||'删除失败','error');});});},
// Page limit
pageCount:function(total,limit){return Math.ceil((total||0)/(limit||20));}
},
watch:{
activeMenu:function(v){
if(v==='dashboard')this.loadDashboard();
else if(v==='machine-list')this.loadMachines();
else if(v==='location-list')this.loadLocations();
else if(v==='online-order')this.loadOrders();
else if(v==='member-list')this.loadMembers();
else if(v==='member-withdraw')this.loadWithdrawals();
else if(v==='member-recharge')this.loadMembers();
else if(v==='complaint-self'){this.complaintType='complaint';this.loadComplaints();}
else if(v==='complaint-wx'){this.complaintType='wechat';this.loadComplaints();}
else if(v==='agent-list')this.loadAgents();
else if(v==='merchant-list')this.loadMerchants();
else if(v==='employee-list')this.loadEmployees();
else if(v==='user-manage')this.loadUsers();
else if(v==='apk-version')this.loadApkVersion();
else if(v==='biz-stat')this.loadStats();
else if(v==='store-record')this.loadAfterSales();
else if(v==='personal-info'){this.loadProfile();}
else if(v==='change-pwd'){this.pwdForm={old:'',new1:'',new2:''};}
else if(v==='settlement'){this.loadSettlementStats();this.loadSettlement(1);}
else if(v==='withdraw-manage'){this.loadWithdrawals(1);}
else if(v==='platform-flow'){this.loadPlatformFlow(1);}
else if(v==='fund-flow'){this.loadFundFlow();}
else if(v==='query-all'){this.queryResults=[];}
else if(v==='company-list'){this.loadCompanies();}
else if(v==='blacklist'){this.loadBlacklist();}
else if(v==='alarm-record'){this.loadAlarms(1);}
else if(v==='location-alarm'){this.loadLocAlarms();}
else if(v==='role-manage'){this.loadRoles();}
else if(v==='cabinet-groups'){this.loadCabinetGroups();}
else if(v==='device-logs'){this.loadDeviceLogs(1);}
else if(v==='door-records'){this.loadDoorRecords(1);}
else if(v==='pending-cmds'){this.loadPendingCmds(1);}
else if(v==='offline-orders'){this.loadOfflineOrders(1);}
else if(v==='cabinet-groups'){this.loadCabinetGroups(1);}
else if(v==='remote-open-logs'){this.loadRemoteOpenLogs(1);}
else if(v==='system-settings'){this.loadSettings();}
else if(v==='data-reset'){this.loadResetStats();}
}
},
mounted:function(){
var og={};menuGroupsData.forEach(function(g){og[g.key]=g.defaultOpen;});this.openGroups=og;this.menuGroupsData=menuGroupsData;
if(localStorage.getItem('admin_token')){this.showLogin=false;this.$nextTick(function(){app.loadDashboard();});}
else{this.$nextTick(function(){setTimeout(function(){app.drawCaptcha();},100);});}
window.addEventListener('resize',function(){app.isMobile=window.innerWidth<=768;});
}
});

// Sidebar component

// Modals moved to #app section


Vue.component('sidebar',{template:'\
<div class="sidebar" :class="{shrink:$parent.isShrink}">\
<div class="sidebar-header"><h3>{{$parent.isShrink?\'⚙️\':\'寄存柜后台\'}}</h3></div>\
<div class="sidebar-body">\
<div v-for="g in menuGroupsData" class="menu-group">\
<div class="menu-group-title" @click="toggleGroup(g.key)"><span>{{g.title}}</span><span class="arrow" :class="{open:$parent.openGroups[g.key]}">▶</span></div>\
<template v-if="$parent.openGroups[g.key]">\
<div v-for="it in g.items" class="menu-item" :class="{active:$parent.activeMenu===it.key}" @click="$parent.activeMenu=it.key"><span class="menu-item-text">{{it.label}}</span></div>\
</template>\
</div>\
</div>\
<div class="sidebar-footer"><div class="user-info">👤 <span>{{$parent.adminUser}}</span></div></div>\
</div>',methods:{toggleGroup:function(k){this.$parent.openGroups[k]=!this.$parent.openGroups[k];Vue.set(this.$parent.openGroups,k,this.$parent.openGroups[k]);}}});

