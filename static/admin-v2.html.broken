// Machine List
Vue.component('page-machine-list',{template:'\
<div>\
<div class="page-box">\
<div class="box-header"><h3>机器列表</h3><div><button class="btn btn-sm btn-blue" @click="$parent.showCabinetModal()">+ 新增设备</button></div></div>\
<div class="search-bar">\
<div class="search-item"><label>关键词</label><input v-model="$parent.machineSearch.keyword" placeholder="编号/名称/主板ID" @keyup.enter="$parent.loadMachines(1)"></div>\
<div class="search-item"><label>状态</label><select v-model="$parent.machineSearch.status" @change="$parent.loadMachines(1)"><option value="">全部</option><option value="online">在线</option><option value="offline">离线</option></select></div>\
<div class="search-item"><label>&nbsp;</label><button class="btn btn-sm btn-blue" @click="$parent.loadMachines(1)">查询</button></div>\
</div>\
<div class="table-scroll"><table><tr><th>ID</th><th>柜体编号</th><th>名称</th><th>网点</th><th>主板ID</th><th>来源</th><th>柜门数</th><th>收费</th><th>营业状态</th><th>设备状态</th><th>APP版本</th><th class="action-col">操作</th></tr>\
<tr v-for="d in $parent.machines"><td>{{d.id}}</td><td>{{d.cabinet_code}}</td><td>{{d.name}}</td><td>{{d.location_name||\'-\'}}</td><td>{{d.mainboard_device_id}}</td><td>{{d.mainboard_source||\'-\'}}</td><td>{{d.total_slots||0}}</td><td><span v-if="d.charge_mode===\'free\'" class="status-tag green">免费</span><span v-else>¥{{d.deposit_amount||0}}</span></td><td><span :class="\'status-tag \'+(d.business_status===\'open\'?\'green\':\'red\')">{{d.business_status===\'open\'?\'营业中\':\'已停业\'}}</span></td><td><span :class="\'status-tag \'+(d.is_online?\'green\':\'gray\')">{{d.is_online?\'在线\':\'离线\'}}</span></td><td><span :style="{color:d.app_version_code<104?\'#f56c6c\':\'#67c23a\',fontWeight:600}">{{d.app_version||\'-\'}}</span><span v-if="d.app_version_code<104&&d.app_version" style="color:#f56c6c;font-size:11px"> 有更新</span></td><td style="white-space:nowrap" class="action-col">\
<button class="btn-sm" style="background:#409eff;color:#fff;border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:12px" @click="$parent.showCabinetModal(d)">编辑</button>\
<button class="btn-sm" style="background:#67c23a;color:#fff;border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:12px" @click="$parent.showSlotModal(d)">柜门</button>\
<button class="btn-sm" style="background:#909399;color:#fff;border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:12px" @click="$parent.showDeviceDetail(d)">详情</button>\
<button class="btn-sm" style="background:#e6a23c;color:#fff;border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:12px" @click="$parent.showDeviceQrcode(d)">二维码</button>\
<button class="btn-sm" style="background:#409eff;color:#fff;border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:12px" :disabled="!d.is_online" @click="$parent.forceUpdateDevice(d)">更新</button>\
<button class="btn-sm" style="background:#909399;color:#fff;border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:12px" @click="$parent.resetActivation(d)">重置</button>\
<button class="btn-sm" :style="{background:d.status===1?\'#f56c6c\':\'#67c23a\',color:\'#fff\',border:\'none\',borderRadius:\'4px\',padding:\'3px 10px\',cursor:\'pointer\',fontSize:\'12px\'}" @click="$parent.toggleCabinetStatus(d)">{{d.status===1?\'停用\':\'启用\'}}</button>\
<button class="btn-sm" style="background:#f56c6c;color:#fff;border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:12px" @click="$parent.deleteCabinet(d)">删除</button>\
</td></tr>\
\
<tr v-if="!$parent.machines.length"><td colspan="12" class="empty-row">暂无数据</td></tr>\
</table></div>\
<div class="pagination"><span>共 {{$parent.machineTotal}} 条</span><div><button :disabled="$parent.machinePage<=1" @click="$parent.loadMachines($parent.machinePage-1)">上一页</button><span style="margin:0 8px">{{$parent.machinePage}} / {{$parent.pageCount($parent.machineTotal,10)||1}}</span><button :disabled="$parent.machinePage>=$parent.pageCount($parent.machineTotal,10)" @click="$parent.loadMachines($parent.machinePage+1)">下一页</button></div></div>\
</div>\
</div>'});

