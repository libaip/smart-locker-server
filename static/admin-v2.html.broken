Vue.component('page-payment-channels',{template:`
<div class="page-box">
<div class="box-header"><h3>支付渠道</h3><button class="btn btn-sm btn-blue" style="float:right" @click="$parent.showChannelModal()">+ 添加渠道</button></div>
<table class="data-table">
<thead><tr><th>ID</th><th>名称</th><th>类型</th><th>商户号</th><th>AppID</th><th>累计金额</th><th>累计笔数</th><th>轮转序号</th><th>操作</th></tr></thead>
<tbody>
<tr v-for="ch in $parent.channels" :key="ch.id">
<td>{{ch.id}}</td>
<td>{{ch.name}}</td>
<td>{{ch.channel_type==='wechat'?'微信':'支付宝'}}</td>
<td>{{ch.mch_id||'-'}}</td>
<td>{{ch.app_id||'-'}}</td>
<td>{{ch.total_amount||0}}</td>
<td>{{ch.total_count||0}}</td>
<td>{{ch.rotation_index||0}}</td>
<td style="white-space:nowrap">
<button class="btn-text" @click="$parent.showChannelModal(ch)">编辑</button>
<button class="btn-text red" @click="$parent.deleteChannel(ch.id)">删除</button>
</td>
</tr>
<tr v-if="!$parent.channels.length"><td colspan="9" class="empty-row">暂无支付渠道</td></tr>
</tbody>
</table>
</div>`,created(){this.$parent.loadChannels();}});

Vue.component('page-system-settings',{template:`
<div class="page-box">
<div class="box-header"><h3>系统设置</h3></div>
<div style="margin-top:16px">
<div style="border-bottom:1px solid #ebeef5;padding-bottom:20px;margin-bottom:20px">
<h4 style="margin:0 0 12px;font-size:15px;color:#303133">基本设置</h4>
<div style="max-width:500px">
<div class="form-group"><label>系统名称</label><input v-model="$parent.settingsData.system_name.value"></div>
<div class="form-group"><label>支付模式</label><select v-model="$parent.settingsData.pay_mode.value"><option value="wechat">微信支付</option><option value="alipay">支付宝</option><option value="both">双通道</option><option value="free">免费模式</option></select></div>
<div class="form-group"><label>保证金金额(元)</label><input type="number" v-model="$parent.settingsData.deposit_amount.value" min="0"></div>
<div class="form-group"><label>超时时间(小时)</label><input type="number" v-model="$parent.settingsData.deposit_timeout.value" min="1" max="720"></div>
<div class="form-group"><label>商户轮转模式</label><select v-model="$parent.settingsData.channel_rotation_mode.value"><option value="round_robin">严格轮转</option><option value="weighted">加权随机</option></select></div>
</div>
</div>
<div style="border-bottom:1px solid #ebeef5;padding-bottom:20px;margin-bottom:20px">
<h4 style="margin:0 0 12px;font-size:15px;color:#303133">风控设置</h4>
<div style="max-width:500px">
<div class="form-group"><label>防刷开启</label><label class="switch"><input type="checkbox" v-model="$parent.settingsData.duplicate_filter_enabled.value" :true-value="'1'" :false-value="'0'"><span class="slider"></span></label></div>
<div class="form-group"><label>防刷天数</label><input type="number" v-model="$parent.settingsData.duplicate_days.value" min="1"></div>
<div class="form-group"><label>防刷次数限制</label><input type="number" v-model="$parent.settingsData.duplicate_limit.value" min="1"></div>
</div>
</div>
<div style="border-bottom:1px solid #ebeef5;padding-bottom:20px;margin-bottom:20px">
<h4 style="margin:0 0 12px;font-size:15px;color:#303133">通知设置</h4>
<div style="max-width:500px">
<div class="form-group"><label>短信通知</label><label class="switch"><input type="checkbox" v-model="$parent.settingsData.sms_enabled.value" :true-value="'true'" :false-value="'false'"><span class="slider"></span></label></div>
</div>
</div>
<div style="padding-bottom:20px">
<h4 style="margin:0 0 12px;font-size:15px;color:#303133">订单隐藏设置</h4>
<div style="max-width:500px">
<div class="form-group"><label>隐藏比例(%)</label><input type="number" v-model="$parent.settingsData.order_hide_rate.value" min="0" max="100"></div>
<div class="form-group"><label>白名单手机号</label><textarea v-model="$parent.settingsData.order_hide_whitelist.value" rows="3" placeholder="多个手机号用逗号分隔"></textarea></div>
</div>
</div>
<div style="text-align:right;padding-top:12px;border-top:1px solid #ebeef5">
<button class="btn btn-blue" @click="$parent.saveSettings()">保存设置</button>
</div>
</div>
</div>`,created(){this.$parent.loadSettings();}});

Vue.component('page-cabinet-groups',{template:`
<div class="page-box">
<div class="box-header"><h3>柜组管理</h3><div><button class="btn btn-sm btn-blue" @click="$parent.showCabinetGroupModal()">+ 新增柜组</button></div></div>
<table><tr><th>ID</th><th>编号</th><th>名称</th><th>网点</th><th>柜体数</th><th>空闲/占用</th><th>操作</th></tr>
<tr v-for="g in $parent.cabinetGroups" :key="g.id"><td>{{g.id}}</td><td>{{g.group_code}}</td><td>{{g.name||'-'}}</td><td>{{g.location_name||'-'}}</td><td>{{g.cabinet_count||0}}</td><td>{{g.available_slots||0}}/{{g.occupied_slots||0}}</td><td style="white-space:nowrap"><button class="btn-text" @click="$parent.showCabinetGroupModal(g)">编辑</button><button class="btn-text red" @click="$parent.deleteCabinetGroup(g)">删除</button></td></tr>
<tr v-if="!$parent.cabinetGroups.length"><td colspan="7" class="empty-row">暂无数据</td></tr>
</table>
<div class="pagination"><span>共 {{$parent.cabinetGroupsTotal}} 条</span><div><button :disabled="$parent.cabinetGroupsPage<=1" @click="$parent.loadCabinetGroups($parent.cabinetGroupsPage-1)">上一页</button><span style="margin:0 8px">{{$parent.cabinetGroupsPage}} / {{$parent.pageCount($parent.cabinetGroupsTotal,10)||1}}</span><button :disabled="$parent.cabinetGroupsPage>=$parent.pageCount($parent.cabinetGroupsTotal,10)" @click="$parent.loadCabinetGroups($parent.cabinetGroupsPage+1)">下一页</button></div></div>
</div>`,created(){this.$parent.loadCabinetGroups();}});

Vue.component('page-device-logs',{template:`
<div class="page-box">
<div class="box-header"><h3>设备日志</h3></div>
<table class="data-table">
<thead><tr><th>ID</th><th>设备ID</th><th>日志类型</th><th>内容</th><th>时间</th></tr></thead>
<tbody>
<tr v-for="log in $parent.deviceLogList" :key="log.id">
<td>{{log.id}}</td><td>{{log.device_id}}</td><td>{{.logTypeText(log.log_type)}}</td><td>{{.logContentText(log.content)}}</td><td>{{.formatTime(log.created_at)}}</td>
</tr>
<tr v-if="$parent.deviceLogList.length===0"><td colspan="5" style="text-align:center;color:#909399;padding:20px">暂无数据</td></tr>
</tbody>
</table>
</div>`,created(){this.$parent.loadDeviceLogs();}});

Vue.component('page-door-records',{template:`
<div class="page-box">
<div class="box-header"><h3>开门记录</h3></div>
<table class="data-table">
<thead><tr><th>ID</th><th>设备ID</th><th>柜门号</th><th>开门方式</th><th>用户手机</th><th>订单号</th><th>时间</th></tr></thead>
<tbody>
<tr v-for="r in $parent.doorRecords" :key="r.id">
<td>{{r.id}}</td><td>{{r.device_id}}</td><td>{{r.slot_id||'-'}}</td><td>{{r.open_type||'-'}}</td><td>{{r.user_phone||'-'}}</td><td>{{r.order_no||'-'}}</td><td>{{r.created_at}}</td>
</tr>
<tr v-if="$parent.doorRecords.length===0"><td colspan="7" style="text-align:center;color:#909399;padding:20px">暂无数据</td></tr>
</tbody>
</table>
</div>`,created(){this.$parent.loadDoorRecords();}});

Vue.component('page-pending-cmds',{template:`
<div class="page-box">
<div class="box-header"><h3>待执行命令</h3></div>
<table class="data-table">
<thead><tr><th>ID</th><th>设备ID</th><th>命令类型</th><th>柜门号</th><th>状态</th><th>创建时间</th><th>操作</th></tr></thead>
<tbody>
<tr v-for="cmd in $parent.pendingCmds" :key="cmd.id">
<td>{{cmd.id}}</td><td>{{cmd.device_id}}</td><td>{{cmd.cmd_type||'-'}}</td><td>{{cmd.slot_id||'-'}}</td>
<td>{{cmd.delivered===0?'待执行':'已执行'}}</td><td>{{cmd.created_at}}</td>
<td><button class="btn btn-sm btn-red" @click="$parent.cancelCmd(cmd.id)" v-if="cmd.delivered===0">取消</button></td>
</tr>
<tr v-if="$parent.pendingCmds.length===0"><td colspan="7" style="text-align:center;color:#909399;padding:20px">暂无数据</td></tr>
</tbody>
</table>
</div>`,created(){this.$parent.loadPendingCmds();}});

</script>
</body>
</html>