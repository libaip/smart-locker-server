/* app.wxss - 全局样式 */

/* 主题色变量 - 蓝紫色渐变 */
page {
  --primary-color: #6C5CE7;
  --primary-light: #A29BFE;
  --primary-dark: #5B4ACB;
  --success-color: #00B894;
  --warning-color: #FDCB6E;
  --danger-color: #E17055;
  --gray-color: #999999;
  --light-gray: #F5F5F5;
  --border-color: #E5E5E5;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  background-color: #F5F5F5;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid var(--primary-color);
}

/* 按钮样式 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #00B894 0%, #55EFC4 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 184, 148, 0.3);
}

.btn-secondary::after {
  border: none;
}

.btn-default {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #FFFFFF;
  color: #6C5CE7;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: 2rpx solid #6C5CE7;
}

.btn-default::after {
  border: none;
}

/* 输入框样式 */
.input-wrapper {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #E5E5E5;
}

.input-wrapper:focus-within {
  border-color: #6C5CE7;
}

.input-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 48rpx;
  font-size: 32rpx;
  color: #333333;
  border: none;
  outline: none;
}

.input-field::placeholder {
  color: #CCCCCC;
}

/* 验证码输入框 */
.code-input-wrapper {
  display: flex;
  align-items: center;
}

.code-input-wrapper .input-wrapper {
  flex: 1;
  margin-bottom: 0;
  margin-right: 20rpx;
}

.code-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.code-btn::after {
  border: none;
}

.code-btn[disabled] {
  background: #CCCCCC;
  color: #FFFFFF;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.status-tag-storing {
  background: linear-gradient(135deg, rgba(108, 92, 231, 0.1) 0%, rgba(162, 155, 254, 0.1) 100%);
  color: #6C5CE7;
}

.status-tag-retrieved {
  background-color: rgba(0, 184, 148, 0.1);
  color: #00B894;
}

/* 列表项 */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.list-item:active {
  background-color: #F8F8F8;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-left {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.list-item-desc {
  font-size: 24rpx;
  color: #999999;
}

.list-item-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #CCCCCC;
  border-right: 3rpx solid #CCCCCC;
  transform: rotate(45deg);
  margin-left: 16rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 50rpx;
}

.empty-state-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #999999;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 50rpx;
  color: #999999;
  font-size: 26rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #E5E5E5;
  margin: 20rpx 0;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 20rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #E5E5E5;
  color: #999999;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  z-index: 1;
}

.step-circle.active {
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
  color: #FFFFFF;
}

.step-circle.completed {
  background-color: #00B894;
  color: #FFFFFF;
}

.step-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

.step-text.active {
  color: #6C5CE7;
}

.step-line {
  width: 120rpx;
  height: 4rpx;
  background-color: #E5E5E5;
  margin: 0 10rpx;
  margin-bottom: 40rpx;
}

.step-line.completed {
  background-color: #00B894;
}

/* 柜格选择卡片 */
.slot-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #E5E5E5;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.slot-card.selected {
  border-color: #6C5CE7;
  background: linear-gradient(135deg, rgba(108, 92, 231, 0.05) 0%, rgba(162, 155, 254, 0.05) 100%);
}

.slot-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
}

.slot-info {
  flex: 1;
  margin-left: 20rpx;
}

.slot-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.slot-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

.slot-count {
  font-size: 28rpx;
  color: #00B894;
  font-weight: 600;
}

.slot-count.empty {
  color: #E17055;
}

/* flex布局辅助类 */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.align-center {
  align-items: center;
}

.align-start {
  align-items: flex-start;
}

.align-end {
  align-items: flex-end;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-around {
  justify-content: space-around;
}

/* 间距辅助类 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.mb-40 { margin-bottom: 40rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 文字辅助类 */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-light { color: var(--text-light); }
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-bold { font-weight: bold; }
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-purple { color: #6C5CE7; }
.text-green { color: #00B894; }
