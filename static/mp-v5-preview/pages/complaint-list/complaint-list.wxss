/* pages/complaint-list/complaint-list.wxss - 投诉记录页面样式 */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 查询区域 */
.search-section {
  margin: 24rpx 30rpx;
}

.search-header {
  margin-bottom: 24rpx;
}

.search-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.search-form {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}

.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.input-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
  white-space: nowrap;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 主色调按钮 */
.btn-primary {
  height: 80rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  border: none;
}

.btn-primary[disabled] {
  background: #CCCCCC;
  color: #FFFFFF;
}

.btn-primary::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background-color: #F0F0F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon text {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 投诉列表 */
.complaints-section {
  padding: 0 30rpx;
}

.complaint-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.complaint-card {
  display: flex;
  flex-direction: column;
}

.complaint-card:active {
  opacity: 0.9;
}

.complaint-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.complaint-type {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.type-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.complaint-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.complaint-status.pending {
  background-color: #FFF3E0;
  color: #FF9800;
}

.complaint-status.processing {
  background-color: #E3F2FD;
  color: #2196F3;
}

.complaint-status.replied {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.complaint-status.closed {
  background-color: #F5F5F5;
  color: #999999;
}

/* 投诉内容区域 */
.complaint-body {
  padding: 20rpx 0;
}

.complaint-content {
  display: flex;
  margin-bottom: 16rpx;
}

.content-label {
  font-size: 26rpx;
  color: #666666;
  white-space: nowrap;
}

.content-text {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
  line-height: 1.5;
}

.complaint-order {
  display: flex;
  margin-bottom: 12rpx;
}

.order-label {
  font-size: 24rpx;
  color: #999999;
  white-space: nowrap;
}

.order-text {
  font-size: 24rpx;
  color: #6C5CE7;
}

.complaint-reply {
  background-color: #F8F8F8;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-top: 16rpx;
}

.reply-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.reply-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.reply-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #4CAF50;
}

.reply-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

/* 投诉底部 */
.complaint-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.create-time {
  font-size: 22rpx;
  color: #999999;
}

.view-detail {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #6C5CE7;
}

.arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #6C5CE7;
  border-right: 2rpx solid #6C5CE7;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

/* 加载中 */
.loading-state {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999999;
}

/* 提示 */
.tips-section {
  margin: 0 30rpx;
}

.tips-card {
  margin-top: 20rpx;
}

.tips-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tips-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.tips-content {
  display: flex;
  flex-direction: column;
}

.tips-content text {
  font-size: 24rpx;
  color: #666666;
  line-height: 2;
}
