/* pages/complaint/complaint.wxss */
.page {
  min-height: 100vh;
  background: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 导航栏 */
.nav {
  background: #fff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  border-bottom: 1rpx solid #f0f0f0;
}
.nav-inner {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  position: relative;
  height: 88rpx;
}
.nav-back { display: flex; align-items: center; }
.nav-back-icon { width: 40rpx; height: 40rpx; }
.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

/* Hero */
.hero {
  background: linear-gradient(135deg, #5BD9D0, #4ECDC4);
  padding: 40rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.hero-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.hero-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}
.hero-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.7;
}

.content {
  padding: 24rpx 32rpx;
}

/* Card */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
  display: block;
}

/* Form */
.form-item {
  margin-bottom: 28rpx;
}
.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}
.form-input {
  width: 100%;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.form-select {
  width: 100%;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background: #fff;
  box-sizing: border-box;
  color: #333;
}
.form-textarea {
  width: 100%;
  min-height: 180rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  resize: none;
}
.char-count {
  font-size: 22rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
  display: block;
}

/* Submit */
.submit-btn {
  display: block;
  width: 100%;
  background: linear-gradient(135deg, #FAD36D, #F0B429);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 26rpx;
  border-radius: 48rpx;
  text-align: center;
  margin-top: 32rpx;
}
.submit-btn.disabled {
  opacity: 0.6;
}

/* Success */
.success-area {
  text-align: center;
  padding: 120rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.success-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}
.msg-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}
.msg-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
  display: block;
}
.back-btn {
  display: inline-block;
  padding: 20rpx 80rpx;
  background: #4ECDC4;
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
}
