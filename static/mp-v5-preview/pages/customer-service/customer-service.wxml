<view class="page">
  <!-- 导航栏 -->
  <view class="nav" style="padding-top:{{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack">
        <image class="nav-back-icon" src="/images/mine_back_arrow_black.png" mode="aspectFit"/>
      </view>
      <text class="nav-title">客服中心</text>
    </view>
  </view>

  <view class="content" style="padding-top:calc(88rpx + {{statusBarHeight}}px);">
    <view class="title-card">
      <text class="company-name">重庆科莱维科技有限公司</text>

      <!-- 微信客服 -->
      <view class="info-row">
        <view class="info-icon" style="background:#E8F8F7">
          <image class="info-icon-img" src="/images/cs_chat.png" mode="aspectFit"/>
        </view>
        <view class="info-text">
          <text class="info-label">微信客服</text>
          <text class="info-value">Kelaiwei_KeFu</text>
        </view>
      </view>

      <!-- 客服电话 -->
      <view class="info-row">
        <view class="info-icon" style="background:#E3F2FD">
          <image class="info-icon-img" src="/images/cs_phone.png" mode="aspectFit"/>
        </view>
        <view class="info-text">
          <text class="info-label">客服电话</text>
          <text class="info-value">4006981080</text>
        </view>
      </view>

      <!-- 营业时间 -->
      <view class="info-row">
        <view class="info-icon" style="background:#FFF3E0">
          <image class="info-icon-img" src="/images/cs_clock.png" mode="aspectFit"/>
        </view>
        <view class="info-text">
          <text class="info-label">营业时间</text>
          <text class="info-value">08:30 - 21:00</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="actions">
        <view class="action-btn btn-complaint" bindtap="goComplaint">
          <image class="action-icon" src="/images/cs_action_complaint.png" mode="aspectFit"/>
          <text>一键投诉</text>
        </view>
        <view class="action-btn btn-call" bindtap="callService">
          <image class="action-icon" src="/images/cs_action_call.png" mode="aspectFit"/>
          <text>一键拨打</text>
        </view>
      </view>
    </view>
  </view>
</view>
