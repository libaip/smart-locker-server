/* pages/customer-service/customer-service.wxss */
.page {
  min-height: 100vh;
  background: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

/* Nav */
.nav {
  background: #fff;
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  border-bottom: 1rpx solid #f0f0f0;
}
.nav-inner {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  position: relative;
  height: 88rpx;
}
.nav-back { display: flex; align-items: center; }
.nav-back-icon { width: 40rpx; height: 40rpx; }
.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.content {
  padding: 32rpx;
}

/* Title Card */
.title-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.company-name {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
  display: block;
  text-align: center;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-row:last-of-type {
  border-bottom: none;
}
.info-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.info-icon-img {
  width: 36rpx;
  height: 36rpx;
}
.info-text {
  display: flex;
  flex-direction: column;
}
.info-label {
  font-size: 22rpx;
  color: #999;
}
.info-value {
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 2rpx;
}

/* Actions */
.actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}
.action-btn {
  flex: 1;
  padding: 26rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #fff;
}
.btn-complaint {
  background: linear-gradient(135deg, #FFB347, #F0A030);
}
.btn-call {
  background: linear-gradient(135deg, #5BD9D0, #4ECDC4);
}
.action-icon {
  width: 36rpx;
  height: 36rpx;
}
