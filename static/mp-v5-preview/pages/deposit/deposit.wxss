/* pages/deposit/deposit.wxss - 存包页面样式 */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 柜体信息 */
.cabinet-info {
  margin: 0 30rpx 30rpx;
}

.cabinet-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.cabinet-location {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666666;
}

.location-icon {
  margin-right: 8rpx;
}

/* 柜格选择 */
.slot-section {
  padding: 0 30rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.slot-list {
  margin-bottom: 40rpx;
}

.slot-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #E5E5E5;
  display: flex;
  align-items: center;
}

.slot-card.selected {
  border-color: #6C5CE7;
  background: linear-gradient(135deg, rgba(108, 92, 231, 0.05) 0%, rgba(162, 155, 254, 0.05) 100%);
}

.slot-card.disabled {
  opacity: 0.5;
}

.slot-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
}

.slot-info {
  flex: 1;
  margin-left: 24rpx;
}

.slot-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.slot-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.slot-count {
  font-size: 28rpx;
  color: #00B894;
  font-weight: 600;
}

.slot-count.empty {
  color: #E17055;
}

/* 步骤底部 */
.step-footer {
  padding: 30rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #F5F5F5;
}

/* 表单区域 */
.form-section {
  margin: 0 30rpx 120rpx;
}

.input-hint {
  display: block;
  font-size: 22rpx;
  color: #E17055;
  margin-top: 10rpx;
}

/* 支付区域 */
.pay-section {
  margin: 0 30rpx 120rpx;
}

.order-summary {
  margin-bottom: 30rpx;
}

.summary-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  font-size: 28rpx;
  color: #666666;
}

.summary-item:last-child {
  border-bottom: none;
}

.pay-amount {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-top: 1rpx solid #F0F0F0;
  margin-top: 20rpx;
}

.amount-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.amount-value {
  display: flex;
  align-items: baseline;
}

.currency {
  font-size: 32rpx;
  color: #E17055;
  font-weight: 600;
}

.money {
  font-size: 56rpx;
  font-weight: 700;
  color: #E17055;
}

.pay-tip {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.tip-icon {
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666666;
}

/* 完成区域 */
.success-section {
  text-align: center;
  padding: 60rpx 30rpx 40rpx;
}

.success-icon {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #00B894 0%, #55EFC4 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.success-icon text {
  font-size: 80rpx;
  color: #FFFFFF;
}

.success-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.success-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
}

.code-display {
  margin: 0 30rpx 30rpx;
  text-align: center;
  background: linear-gradient(135deg, #6C5CE7 0%, #A29BFE 100%);
}

.code-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

.code-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
}

.code-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.order-info {
  margin: 0 30rpx 120rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}
