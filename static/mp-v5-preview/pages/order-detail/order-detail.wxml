<!-- pages/order-detail/order-detail.wxml - 订单详情页面 -->
<view class="container">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 订单详情 -->
  <view class="detail-content" wx:if="{{!loading && orderInfo.order_id}}">
    <!-- 状态卡片 -->
    <view class="status-card">
      <view class="status-header">
        <text class="status-icon" wx:if="{{orderInfo.status === 'storing'}}">📦</text>
        <text class="status-icon" wx:elif="{{orderInfo.status === 'retrieved'}}">✓</text>
        <text class="status-icon" wx:else>⏱</text>
        <view class="status-info">
          <text class="status-text {{orderInfo.status_class}}">{{orderInfo.status_text}}</text>
          <text class="order-no">订单号：{{orderInfo.order_no}}</text>
        </view>
      </view>
    </view>

    <!-- 位置信息 -->
    <view class="section card">
      <view class="section-title">寄存信息</view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">寄存地点</text>
          <text class="info-value">{{orderInfo.cabinet_name}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">柜格号</text>
          <text class="info-value text-purple">{{orderInfo.slot_no}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">柜格大小</text>
          <text class="info-value">{{orderInfo.slot_size_name}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">存入时间</text>
          <text class="info-value">{{orderInfo.deposit_time || '--'}}</text>
        </view>
        <view class="info-row" wx:if="{{orderInfo.retrieve_time}}">
          <text class="info-label">取出时间</text>
          <text class="info-value">{{orderInfo.retrieve_time}}</text>
        </view>
        <view class="info-row" wx:if="{{orderInfo.end_time}}">
          <text class="info-label">结束时间</text>
          <text class="info-value">{{orderInfo.end_time}}</text>
        </view>
      </view>
    </view>

    <!-- 费用信息 -->
    <view class="section card">
      <view class="section-title">费用信息</view>
      <view class="info-list">
        <view class="info-row">
          <text class="info-label">保证金</text>
          <text class="info-value">¥{{orderInfo.deposit}}</text>
        </view>
        <view class="info-row" wx:if="{{orderInfo.fee > 0}}">
          <text class="info-label">超时费用</text>
          <text class="info-value text-warning">-¥{{orderInfo.fee}}</text>
        </view>
        <view class="info-row" wx:if="{{orderInfo.refund_amount > 0}}">
          <text class="info-label">已退款</text>
          <text class="info-value text-success">¥{{orderInfo.refund_amount}}</text>
        </view>
        <view class="info-row highlight" wx:if="{{orderInfo.status === 'storing'}}">
          <text class="info-label">取物后预计退款</text>
          <text class="info-value text-primary">¥{{orderInfo.deposit - orderInfo.fee}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮区域 -->
    <view class="action-section" wx:if="{{orderInfo.status === 'storing'}}">
      <!-- 提现退款按钮 -->
      <button 
        class="btn-withdraw" 
        wx:if="{{withdrawEnabled}}"
        bindtap="onApplyWithdrawal"
        disabled="{{isWithdrawing || withdrawStatus === 'pending' || withdrawStatus === 'approved'}}"
      >
        {{isWithdrawing ? '退款处理中...' : withdrawStatus === 'pending' ? '审核中' : withdrawStatus === 'approved' || withdrawStatus === 'auto_refund' ? '已退款' : '申请退款'}}
      </button>
      
      <!-- 继续寄存按钮 -->
      <button class="btn-secondary" bindtap="onContinueStorage" wx:if="{{withdrawStatus !== 'pending' && withdrawStatus !== 'approved' && withdrawStatus !== 'auto_refund'}}">
        继续寄存
      </button>
    </view>

    <!-- 底部操作 -->
    <view class="bottom-actions">
      <!-- 投诉按钮 -->
      <view class="action-item" bindtap="onComplaint">
        <text class="action-icon">📝</text>
        <text class="action-text">投诉</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && !orderInfo.order_id}}">
    <text>订单不存在</text>
  </view>
</view>
