<view class="page">
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-arrow">‹</text>
    </view>
    <text class="nav-title">交易明细</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 筛选tabs -->
  <view class="tabs">
    <view class="tab {{filter==='all'?'tab-active':''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab {{filter==='income'?'tab-active':''}}" bindtap="switchTab" data-tab="income">收入</view>
    <view class="tab {{filter==='expense'?'tab-active':''}}" bindtap="switchTab" data-tab="expense">支出</view>
  </view>

  <view wx:if="{{list.length === 0}}" class="empty">暂无交易记录</view>

  <view class="card-list">
    <view class="tx-card" wx:for="{{list}}" wx:key="id">
      <view class="tx-row">
        <text class="tx-label">订单编号：</text>
        <text class="tx-value">{{item.order_no || '-'}}</text>
      </view>
      <view class="tx-row">
        <text class="tx-label">交易类型：</text>
        <text class="tx-value">{{item.remark || (item.amount > 0 ? '收入' : '支出')}}</text>
        <view wx:if="{{item.isWithdraw && item.status === 0}}" class="tx-tip-right">
          <text class="tx-tip-text">预计1-3个工作日到账 请耐心等待… 超时请联系客服</text>
        </view>
      </view>
      <view class="tx-row">
        <text class="tx-label">交易金额：</text>
        <text class="tx-amount">{{item.amount > 0 ? '+' : ''}}{{item.amount}}</text>
      </view>
      <view class="tx-row">
        <text class="tx-label">交易时间：</text>
        <text class="tx-value">{{item.source_time || ''}}</text>
      </view>
    </view>
  </view>
</view>
