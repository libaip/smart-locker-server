/* pages/wallet/wallet.wxss */
.page {
  min-height: 100vh;
  background: #f0f0f0;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

/* Header */
.header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 0 32rpx;
}
.back {
  position: absolute;
  left: 32rpx;
  display: flex;
  align-items: center;
}
.back-icon { width: 40rpx; height: 40rpx; }
.title { font-size: 36rpx; color: #333; font-weight: 500; }

/* Balance Card */
.balance-card {
  background: linear-gradient(135deg, #5ec9b4 0%, #4ec9a8 100%);
  border-radius: 24rpx;
  margin: 32rpx;
  padding: 48rpx 40rpx;
  position: relative;
  min-height: 280rpx;
  overflow: hidden;
}
.balance-decor {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.balance-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 16rpx;
  display: block;
}
.balance-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}
.balance-currency {
  font-size: 40rpx;
  color: #fff;
  font-weight: 500;
  line-height: 80rpx;
}
.balance-amount {
  font-size: 96rpx;
  color: #fff;
  font-weight: 700;
  line-height: 104rpx;
}
.balance-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.btn-withdraw {
  background: #fff;
  color: #5ec9b4;
  border: none;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.btn-rule {
  background: rgba(255,255,255,0.2);
  color: #fff;
  border: none;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* List */
.list-section {
  padding: 32rpx 0;
}
.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 40rpx;
  background: #fff;
}
.list-item:active { background: #f5f5f5; }
.list-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fdf3e0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.list-icon-img {
  width: 44rpx;
  height: 44rpx;
}
.label {
  margin-left: 28rpx;
  font-size: 32rpx;
  color: #333;
  flex: 1;
}
.arrow {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

/* Floating buttons */
.floating-btns {
  position: fixed;
  right: 32rpx;
  bottom: 160rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  z-index: 100;
}
.float-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.float-icon {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}
.float-icon.robot {
  background: linear-gradient(135deg, #5ec9b4, #45b89e);
}
.float-icon.complaint {
  background: linear-gradient(135deg, #f5c542, #e6b530);
}
.float-icon-img {
  width: 96rpx;
  height: 96rpx;
}
.float-label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}
